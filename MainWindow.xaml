<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TiHiY.StreamControlCenter.Models"
        x:Class="TiHiY.StreamControlCenter.MainWindow"
        Title="TiHiY StreamControl Center — Ukraine"
        Width="1672" Height="941" MinWidth="1200" MinHeight="700"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Loaded="Window_Loaded" Closing="Window_Closing" SizeChanged="Window_SizeChanged"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        Background="#020817" FontFamily="Segoe UI" Foreground="#EAF6FF">

    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock" BasedOn="{StaticResource UkraineHeaderText}"/>
        <Style x:Key="TinyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7FA0B5"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="LayoutSplitter" TargetType="GridSplitter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ShowsPreview" Value="False"/>
            <Setter Property="DragIncrement" Value="3"/>
            <Setter Property="KeyboardIncrement" Value="6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="GridSplitter"><Border Background="Transparent"/></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="IconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#F5A900"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PanelSectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F5A900"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="TinyActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="10.5"/>
        </Style>
        <Style x:Key="StatusCardButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><ContentPresenter/></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="MixerSlider" TargetType="Slider">
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Border Height="7" VerticalAlignment="Center" CornerRadius="3" Background="#020A12" BorderBrush="#285A78" BorderThickness="1"/>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton><RepeatButton Command="Slider.DecreaseLarge" Background="Transparent" BorderThickness="0" Template="{x:Null}"/></Track.DecreaseRepeatButton>
                                <Track.Thumb><Thumb Width="14" Height="14"><Thumb.Template><ControlTemplate TargetType="Thumb"><Ellipse Fill="#E9E1D4" Stroke="#FFFFFF" StrokeThickness="1"/></ControlTemplate></Thumb.Template></Thumb></Track.Thumb>
                                <Track.IncreaseRepeatButton><RepeatButton Command="Slider.IncreaseLarge" Background="Transparent" BorderThickness="0" Template="{x:Null}"/></Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MetricCircle" TargetType="Border">
            <Setter Property="Width" Value="92"/>
            <Setter Property="Height" Value="92"/>
            <Setter Property="CornerRadius" Value="46"/>
            <Setter Property="Background" Value="#C9051424"/>
            <Setter Property="BorderBrush" Value="#168ED8"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Margin" Value="8,2"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource UkraineWindowBrush}" BorderBrush="#0FA5EA" BorderThickness="1">
        <Grid>
            <Path IsHitTestVisible="False" Margin="6" Fill="Transparent" Stroke="#9C0D87C9" StrokeThickness="1.2" Stretch="Fill" Data="M18,0 L982,0 L1000,18 L1000,482 L982,500 L18,500 L0,482 L0,18 Z"/>
            <Grid x:Name="DesignSurface" Margin="8" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="88"/>
                    <RowDefinition Height="52"/>
                    <RowDefinition x:Name="DashboardRow" Height="*" MinHeight="470"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition x:Name="FooterRow" Height="178" MinHeight="145" MaxHeight="240"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" ClipToBounds="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Source="/TiHiY.StreamControlCenter;component/Assets/Themes/UkraineExact/header-emblem.png" Width="142" Height="156" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-8,-8,0,0" Opacity="{DynamicResource ThemePremiumAccentOpacity}" IsHitTestVisible="False" Panel.ZIndex="3"/>
                    <Image Source="/TiHiY.StreamControlCenter;component/Assets/Themes/UkraineExact/header-wheat.png" Width="190" Height="92" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="610,-2,0,0" Opacity="{DynamicResource ThemePremiumAccentOpacity}" IsHitTestVisible="False"/>
                    <Image Source="/TiHiY.StreamControlCenter;component/Assets/Themes/UkraineExact/header-map.png" Width="190" Height="96" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="835,-2,0,0" Opacity="{DynamicResource ThemePremiumAccentOpacity}" IsHitTestVisible="False"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="150,0,0,0">
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="TiHiY" FontSize="38" FontWeight="Black" Foreground="#F2F5F9"/>
                                <TextBlock Text="  StreamControl Center" FontSize="34" FontWeight="Bold" Foreground="#F5A900"/>
                            </StackPanel>
                            <TextBlock Text="MULTICHAT  •  DONATIONS  •  OBS AUDIO  •  MUSIC" Foreground="#7E91A2" FontSize="12" FontWeight="SemiBold" Margin="2,1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                        <TextBlock Text="МАСШТАБ" Foreground="#8499AA" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <Button Content="−" Width="38" Style="{StaticResource WindowButton}" Click="ZoomOut_Click"/>
                        <Button x:Name="ZoomTextButton" Content="100%" Width="76" Style="{StaticResource WindowButton}" Click="ZoomAuto_Click"/>
                        <Button Content="+" Width="38" Style="{StaticResource WindowButton}" Click="ZoomIn_Click"/>
                        <Button x:Name="LayoutEditButton" Content="МАКЕТ: ЗАКРІПЛЕНО" MinWidth="142" Style="{StaticResource WindowButton}" Click="ToggleLayoutEdit_Click" ToolTip="Редагування розташування блоків"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowButton}" Content="—" Click="Minimize_Click"/>
                        <Button Style="{StaticResource WindowButton}" Content="□" Click="Maximize_Click"/>
                        <Button Style="{StaticResource DangerButton}" Content="×" Click="Close_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="104,0,0,5">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Button x:Name="ConnectObsButton" Style="{StaticResource StatusCardButton}" Click="ConnectObs_Click">
                            <Border Style="{StaticResource CompactStatusPill}" MinWidth="142"><StackPanel Orientation="Horizontal"><Ellipse x:Name="ObsDot" Width="11" Height="11" Fill="#18D76B" Margin="0,0,7,0"/><StackPanel><TextBlock Text="OBS AUDIO" FontWeight="Bold" FontSize="10"/><TextBlock x:Name="ObsStatusText" Text="ПІДКЛЮЧЕНО" Foreground="#27E57B" FontWeight="Bold" FontSize="9"/><TextBlock x:Name="ConnectObsButtonText" Text="OBS" Visibility="Collapsed"/></StackPanel></StackPanel></Border>
                        </Button>
                        <Border Style="{StaticResource CompactStatusPill}" MinWidth="142"><StackPanel Orientation="Horizontal"><Ellipse x:Name="BridgeDot" Width="11" Height="11" Fill="#F5A900" Margin="0,0,7,0"/><StackPanel><TextBlock Text="MULTISTREAM" FontWeight="Bold" FontSize="10"/><TextBlock x:Name="BridgeStatusText" Text="2 / 2 ПЕРЕДАЧІ" Foreground="#FFD12D" FontWeight="Bold" FontSize="9"/></StackPanel></StackPanel></Border>
                        <Border Style="{StaticResource CompactStatusPill}" BorderBrush="#8D48D8" MinWidth="142"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" Width="21" Height="21"/><StackPanel Margin="6,0,0,0"><TextBlock Text="TWITCH" FontWeight="Bold" FontSize="10"/><TextBlock x:Name="TwitchTopStatusText" Text="ПІДКЛЮЧЕНО" Foreground="#B88AFF" FontWeight="Bold" FontSize="9"/></StackPanel></StackPanel></Border>
                        <Border Style="{StaticResource CompactStatusPill}" BorderBrush="#D33A42" MinWidth="142"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Width="22" Height="20"/><StackPanel Margin="6,0,0,0"><TextBlock Text="YOUTUBE" FontWeight="Bold" FontSize="10"/><TextBlock x:Name="YouTubeTopStatusText" Text="ПІДКЛЮЧЕНО" Foreground="#FF5A62" FontWeight="Bold" FontSize="9"/></StackPanel></StackPanel></Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Click="OpenSettings_Click" Style="{StaticResource CompactTopActionButton}" MinWidth="162"><StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource IconGlyph}" Text="&#xE713;"/><TextBlock Text="  НАЛАШТУВАННЯ"/></StackPanel></Button>
                        <Button Click="OpenYouTubeStudioDashboard_Click" Style="{StaticResource CompactTopRedActionButton}" MinWidth="162"><StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource IconGlyph}" Text="&#xE789;" Foreground="#FF3946"/><TextBlock Text="  ТРАНСЛЯЦІЯ"/></StackPanel></Button>
                        <Button Click="OpenMusic_Click" Style="{StaticResource CompactTopActionButton}" MinWidth="162"><StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource IconGlyph}" Text="&#xE189;"/><TextBlock Text="  МУЗИЧНИЙ ПЛЕЄР"/></StackPanel></Button>
                    </StackPanel>
                </Grid>

                <Grid x:Name="DashboardBlocksGrid" Grid.Row="2" Margin="0,0,0,4">
                    <Grid.RowDefinitions><RowDefinition x:Name="MainTopRow" Height="1.12*" MinHeight="260"/><RowDefinition Height="7"/><RowDefinition x:Name="MainBottomRow" Height="0.88*" MinHeight="210"/></Grid.RowDefinitions>
                    <Grid x:Name="TopBlocksGrid" Grid.Row="0">
                        <Grid.ColumnDefinitions><ColumnDefinition x:Name="TopLeftColumn" Width="1*" MinWidth="430"/><ColumnDefinition Width="7"/><ColumnDefinition x:Name="TopRightColumn" Width="1*" MinWidth="430"/></Grid.ColumnDefinitions>
                        <GridSplitter Grid.Column="1" Style="{StaticResource LayoutSplitter}" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Cursor="SizeWE" DragCompleted="LayoutSplitter_DragCompleted" MouseDoubleClick="LayoutSplitter_MouseDoubleClick"/>
                        <ContentControl x:Name="ChatBlockPanel" Grid.Column="0" Style="{StaticResource HudPanel}" Margin="0,0,3,0" Padding="18,12,16,12" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="*"/><RowDefinition Height="44"/></Grid.RowDefinitions>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="МУЛЬТИЧАТ • TWITCH + YOUTUBE" Style="{StaticResource HeaderText}"/><TextBlock x:Name="ChatStatusText" Text="Об’єднаний чат ваших трансляцій у реальному часі" Style="{StaticResource TinyLabel}" Margin="0,3,0,0"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Border Background="#2D1742" BorderBrush="#8F4FE2" BorderThickness="1.2" CornerRadius="4" Padding="9,4" Margin="3"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" Width="21" Height="21"/><TextBlock x:Name="TwitchViewerText" Text="0" FontSize="17" Margin="7,0"/><Ellipse x:Name="TwitchLiveDot" Width="7" Height="7" Fill="#1CD66D"/><TextBlock x:Name="TwitchLiveText" Text="ON" Visibility="Collapsed"/></StackPanel></Border><Border Background="#351219" BorderBrush="#D33942" BorderThickness="1.2" CornerRadius="4" Padding="9,4" Margin="3"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Width="23" Height="21"/><TextBlock x:Name="YouTubeViewerText" Text="0" FontSize="17" Margin="7,0,5,0"/><TextBlock Text="♥" Foreground="#FF5B64" FontSize="16" Margin="3,0"/><TextBlock x:Name="YouTubeLikesText" Text="0" FontSize="16" Margin="2,0,5,0"/><Ellipse x:Name="YouTubeLiveDot" Width="7" Height="7" Fill="#1CD66D"/><TextBlock x:Name="YouTubeLiveText" Text="ON" Visibility="Collapsed"/></StackPanel></Border></StackPanel></Grid>
                                <Border Grid.Row="1" Background="#D0010A13" BorderBrush="#164C71" BorderThickness="1" CornerRadius="4" Padding="8,5"><Grid><ListBox x:Name="MainChatList" ItemsSource="{Binding MainChatMessages}" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" PreviewMouseRightButtonDown="MainChatList_PreviewMouseRightButtonDown" Background="Transparent" BorderThickness="0"><ListBox.ItemTemplate><DataTemplate DataType="{x:Type models:ChatMessage}"><Border Background="{Binding Background}" Padding="3,5"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="76"/><ColumnDefinition Width="32"/><ColumnDefinition Width="145"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="{Binding DisplayTime}" Foreground="#71899C" FontFamily="Consolas" FontSize="11"/><Border Grid.Column="1" Width="21" Height="21" CornerRadius="3" Background="{Binding PlatformColor}" HorizontalAlignment="Left"><Image Source="{Binding PlatformIconPath}" Margin="2"/></Border><TextBlock Grid.Column="2" Text="{Binding User}" Foreground="{Binding Foreground}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Column="3" Text="{Binding Text}" TextWrapping="Wrap" Foreground="#DCE9F3"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox><TextBlock x:Name="ChatEmptyStateText" Text="Підключіть Twitch або YouTube у налаштуваннях каналів." Foreground="#7891A4" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420" FontSize="13"/></Grid></Border>
                                <Grid Grid.Row="2" Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/><ColumnDefinition Width="0.62*"/><ColumnDefinition Width="0.62*"/><ColumnDefinition Width="0.48*"/></Grid.ColumnDefinitions><TextBox x:Name="ChatInput" KeyDown="ChatInput_KeyDown" ToolTip="Напишіть повідомлення…" MinHeight="34" VerticalContentAlignment="Center" Background="#071525" BorderBrush="#285A7B" Foreground="#EAF6FF" Padding="10,4"/><Button Grid.Column="1" Content="➤" Style="{StaticResource TinyActionButton}" Click="SendBoth_Click"/><Button x:Name="SendTwitchButton" Grid.Column="2" Click="SendTwitch_Click" Style="{StaticResource TinyActionButton}" BorderBrush="#8D4CDA"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" Width="18" Height="18"/><TextBlock Text="  TWITCH"/></StackPanel></Button><Button x:Name="SendYouTubeButton" Grid.Column="3" Click="SendYouTube_Click" Style="{StaticResource TinyActionButton}" BorderBrush="#D4363F"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Width="19" Height="18"/><TextBlock Text="  YOUTUBE"/></StackPanel></Button><Button x:Name="SendBothButton" Grid.Column="4" Click="SendBoth_Click" Style="{StaticResource TinyActionButton}" Content="ОБИДВА"/></Grid>
                            </Grid>
                        </ContentControl>
                        <ContentControl x:Name="DonationsBlockPanel" Grid.Column="2" Style="{StaticResource HudPanel}" Margin="3,0,0,0" Padding="18,12,16,12" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/><RowDefinition Height="38"/></Grid.RowDefinitions>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="ДОНАТИ" Style="{StaticResource HeaderText}"/><TextBlock x:Name="DonatelloStatusText" Grid.Column="1" Text="DONATELLO • ПІДКЛЮЧЕНО" Foreground="#22DA72" FontSize="10" VerticalAlignment="Center"/></Grid>
                                <Grid Grid.Row="1"><ListBox ItemsSource="{Binding RecentDonations}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto"><ListBox.ItemTemplate><DataTemplate DataType="{x:Type models:DonationEvent}"><Border Background="#AF061527" BorderBrush="#163E5B" BorderThickness="0,0,0,1" CornerRadius="4" Padding="10,7" Margin="0,2"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="58"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions><Border Width="46" Height="46" CornerRadius="23" BorderBrush="#E5A300" BorderThickness="1.4" Background="#07182A"><TextBlock Text="{Binding EventIcon}" Foreground="#F5A900" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="1"><TextBlock Text="{Binding User}" FontWeight="Bold" FontSize="17"/><TextBlock Text="{Binding DisplayAmount}" Foreground="#FFD12D" FontWeight="Black" FontSize="22"/><TextBlock Text="{Binding Message}" Foreground="#DCE9F3" TextTrimming="CharacterEllipsis" FontSize="12"/></StackPanel><TextBlock Grid.Column="2" Text="{Binding DisplayTime}" Foreground="#A8BAC7" FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox><TextBlock x:Name="RecentDonationsEmptyText" Text="Останніх донатів ще не отримано" Foreground="#7891A4" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
                                <Button Grid.Row="2" Click="OpenDonatello_Click" Style="{StaticResource TinyActionButton}" HorizontalAlignment="Stretch"><StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Style="{StaticResource IconGlyph}" Text="&#xE8C7;" FontSize="15"/><TextBlock Text="  ВІДКРИТИ ДОНАТИ / ВІДЖЕТИ"/></StackPanel></Button>
                            </Grid>
                        </ContentControl>
                    </Grid>
                    <GridSplitter Grid.Row="1" Style="{StaticResource LayoutSplitter}" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Cursor="SizeNS" DragCompleted="LayoutSplitter_DragCompleted" MouseDoubleClick="LayoutSplitter_MouseDoubleClick"/>
                    <Grid x:Name="BottomBlocksGrid" Grid.Row="2">
                        <Grid.ColumnDefinitions><ColumnDefinition x:Name="BottomLeftColumn" Width="1*" MinWidth="430"/><ColumnDefinition Width="7"/><ColumnDefinition x:Name="BottomRightColumn" Width="1*" MinWidth="430"/></Grid.ColumnDefinitions>
                        <GridSplitter Grid.Column="1" Style="{StaticResource LayoutSplitter}" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Cursor="SizeWE" DragCompleted="LayoutSplitter_DragCompleted" MouseDoubleClick="LayoutSplitter_MouseDoubleClick"/>
                        <ContentControl x:Name="MixerBlockPanel" Grid.Column="0" Style="{StaticResource HudPanel}" Margin="0,0,3,0" Padding="18,11,16,10" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/><RowDefinition Height="38"/></Grid.RowDefinitions><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="ШВИДКИЙ МІКШЕР • AUDIO MIXER OBS" Style="{StaticResource HeaderText}"/><TextBlock Text="Реальні канали OBS • гучність • Mute" Style="{StaticResource TinyLabel}" Margin="0,2,0,0"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal"><TextBlock x:Name="AudioStatusText" Text="6 каналів" Foreground="#8299AA" VerticalAlignment="Center" Margin="0,0,7,0"/><TextBlock x:Name="AudioPageText" Text="1 / 1" Foreground="#8299AA" VerticalAlignment="Center"/></StackPanel></Grid><Grid Grid.Row="1"><ItemsControl ItemsSource="{Binding QuickAudioPage}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate DataType="{x:Type models:AudioChannel}"><Border Background="#BE061527" BorderBrush="#174A70" BorderThickness="1" CornerRadius="4" Margin="0,2" Padding="7,3"><Grid Height="32"><Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="76"/><ColumnDefinition Width="38"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions><Border Width="30" Height="28" Background="#07192C" BorderBrush="#D59000" BorderThickness="1" CornerRadius="4"><TextBlock Style="{StaticResource IconGlyph}" Text="{Binding IconGlyph}" FontSize="15"/></Border><TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/><Grid Grid.Column="2" Margin="6,0,10,0"><ProgressBar Minimum="0" Maximum="1" Value="{Binding Meter}" Height="8" VerticalAlignment="Center" Background="#01080F" BorderBrush="#285A78" BorderThickness="1"><ProgressBar.Foreground><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#17D766" Offset="0"/><GradientStop Color="#AEE139" Offset="0.62"/><GradientStop Color="#F5B000" Offset="0.82"/><GradientStop Color="#FF4C58" Offset="1"/></LinearGradientBrush></ProgressBar.Foreground></ProgressBar><Slider Tag="{Binding}" Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}" ValueChanged="QuickVolumeSlider_ValueChanged" Style="{StaticResource MixerSlider}"/></Grid><TextBlock Grid.Column="3" Text="{Binding DbText}" Foreground="#FFB000" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/><Button Grid.Column="4" Tag="{Binding}" Click="QuickMute_Click" Content="🔇" Style="{StaticResource TinyActionButton}" Width="34" ToolTip="{Binding MuteText}"/><Button Grid.Column="5" Content="⋮" Style="{StaticResource TinyActionButton}" Width="34" Click="OpenAudio_Click"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock x:Name="AudioEmptyStateText" Text="Підключіть OBS WebSocket, щоб завантажити реальні канали мікшера." Foreground="#7891A4" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="440" FontSize="13"/></Grid><Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Orientation="Horizontal"><Button Content="‹" Style="{StaticResource TinyActionButton}" Width="38" Click="PreviousAudioPage_Click"/><Button Content="›" Style="{StaticResource TinyActionButton}" Width="38" Click="NextAudioPage_Click"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"><Ellipse Width="9" Height="9" Fill="#17D766" Margin="0,0,7,0"/><TextBlock Text="OBS підключено" Foreground="#17D766"/></StackPanel><Button Grid.Column="2" Click="OpenAudio_Click" Style="{StaticResource TinyActionButton}"><StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource IconGlyph}" Text="&#xE9D9;" FontSize="15"/><TextBlock Text="  ВІДКРИТИ ПОВНИЙ МІКШЕР"/></StackPanel></Button></Grid></Grid>
                        </ContentControl>
                        <ContentControl x:Name="NotificationsBlockPanel" Grid.Column="2" Style="{StaticResource HudPanel}" Margin="3,0,0,0" Padding="18,11,16,10" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop">
