<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:models="clr-namespace:TiHiY.StreamControlCenter.Models" x:Class="TiHiY.StreamControlCenter.MainWindow" Title="TiHiY StreamControl Center v1.0.5.2 — Ukraine Approved Visual Theme" Width="1672" Height="941" MinWidth="780" MinHeight="500" WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Closing="Window_Closing" SizeChanged="Window_SizeChanged" PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Cyan}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18.5"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>
        <Style x:Key="TinyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="LayoutSplitter" TargetType="GridSplitter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ShowsPreview" Value="False"/>
            <Setter Property="DragIncrement" Value="3"/>
            <Setter Property="KeyboardIncrement" Value="6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{DynamicResource Amber}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <DataTemplate x:Key="ModuleContentTemplate">
            <Grid Margin="0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Width="25" Height="25" CornerRadius="13" Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Cyan2}" BorderThickness="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}" Style="{StaticResource IconGlyph}" FontSize="14.5"/>
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding}" TextAlignment="Left" TextWrapping="Wrap" FontWeight="SemiBold" FontSize="9.2" LineHeight="10.2" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="6,0,2,0"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="BrandModuleContentTemplate">
            <Grid Margin="0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Width="25" Height="25" CornerRadius="13" Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Cyan2}" BorderThickness="1" VerticalAlignment="Center">
                    <Image Source="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}" Width="17" Height="17" Stretch="Uniform"/>
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding}" TextAlignment="Left" TextWrapping="Wrap" FontWeight="SemiBold" FontSize="9.2" LineHeight="10.2" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="6,0,2,0"/>
            </Grid>
        </DataTemplate><Style x:Key="MixerSlider" TargetType="Slider">
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton><RepeatButton Command="Slider.DecreaseLarge" Background="Transparent" BorderThickness="0" Template="{x:Null}"/></Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="13" Height="13">
                                        <Thumb.Template><ControlTemplate TargetType="Thumb"><Ellipse Fill="{DynamicResource Amber}" Stroke="#FFCF61" StrokeThickness="1" Effect="{StaticResource AmberGlow}"/></ControlTemplate></Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton><RepeatButton Command="Slider.IncreaseLarge" Background="Transparent" BorderThickness="0" Template="{x:Null}"/></Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="VerticalMixerSlider" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="IsDirectionReversed" Value="False"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Width="18" Background="Transparent">
                            <Border Width="8" Background="#09111A" BorderBrush="#35596B" BorderThickness="1" CornerRadius="3" HorizontalAlignment="Center"/>
                            <Track x:Name="PART_Track" Orientation="Vertical" HorizontalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Width="6" Background="#2D72A9" BorderThickness="0" Template="{x:Null}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="10">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#E7EAF0" BorderBrush="#FFFFFF" BorderThickness="1" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Width="6" Background="Transparent" BorderThickness="0" Template="{x:Null}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VerticalMeter" TargetType="ProgressBar">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Background" Value="#10161D"/>
            <Setter Property="BorderBrush" Value="#2B3642"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2"/>
                            <Grid x:Name="PART_Track" Margin="1">
                                <Border x:Name="PART_Indicator" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" CornerRadius="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                            <GradientStop Color="#12E457" Offset="0"/>
                                            <GradientStop Color="#6BF22C" Offset="0.48"/>
                                            <GradientStop Color="#D6E83B" Offset="0.70"/>
                                            <GradientStop Color="#E29F20" Offset="0.84"/>
                                            <GradientStop Color="#B52B39" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                            <UniformGrid Rows="10" IsHitTestVisible="False" Opacity="0.45">
                                <Border BorderBrush="#18202A" BorderThickness="0,0,0,1"/><Border BorderBrush="#18202A" BorderThickness="0,0,0,1"/>
                                <Border BorderBrush="#18202A" BorderThickness="0,0,0,1"/><Border BorderBrush="#18202A" BorderThickness="0,0,0,1"/>
                                <Border BorderBrush="#18202A" BorderThickness="0,0,0,1"/><Border BorderBrush="#18202A" BorderThickness="0,0,0,1"/>
                                <Border BorderBrush="#18202A" BorderThickness="0,0,0,1"/><Border BorderBrush="#18202A" BorderThickness="0,0,0,1"/>
                                <Border BorderBrush="#18202A" BorderThickness="0,0,0,1"/><Border/>
                            </UniformGrid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="{DynamicResource WindowGradient}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
        <Grid>
            <Image Source="{DynamicResource ThemeMapImage}" Opacity="0.34" Width="300" Height="180"
                   Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,360,0" IsHitTestVisible="False"/>
            <Image Source="{DynamicResource ThemeWheatImage}" Opacity="0.72" Width="250" Height="78"
                   Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="520,0,0,0" IsHitTestVisible="False"/>
            <Image Source="{DynamicResource ThemeOrnamentImage}"
                   Opacity="{DynamicResource ThemeOrnamentOpacity}"
                   Width="520" Height="20" Stretch="UniformToFill" HorizontalAlignment="Center"
                   VerticalAlignment="Top" Margin="0,3,0,0" IsHitTestVisible="False"/>
            <Path IsHitTestVisible="False" Margin="5" Fill="Transparent" Stroke="{DynamicResource LineSoft}" StrokeThickness="1" Stretch="Fill" Data="M14,0 L986,0 L1000,14 L1000,486 L986,500 L14,500 L0,486 L0,14 Z"/>
            <Path IsHitTestVisible="False" Data="M0,34 L0,8 L8,0 L74,0" Stroke="{DynamicResource Cyan}" StrokeThickness="1.4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="9"/>
            <Path IsHitTestVisible="False" Data="M74,34 L74,8 L66,0 L0,0" Stroke="{DynamicResource Amber}" StrokeThickness="1.4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="9"/>
            <Path IsHitTestVisible="False" Data="M0,0 L0,26 L8,34 L74,34" Stroke="{DynamicResource Cyan}" StrokeThickness="1.4" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="9"/>
            <Path IsHitTestVisible="False" Data="M74,0 L74,26 L66,34 L0,34" Stroke="{DynamicResource Amber}" StrokeThickness="1.4" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="9"/>
            <Viewbox Stretch="Fill" Opacity="0.075" IsHitTestVisible="False">
                <Canvas Width="1672" Height="941">
                    <Path Stroke="#2BD8FF" StrokeThickness="2" Data="M20,172 H210 V120 H410 M70,622 H270 V702 H480 M1312,125 H1472 V205 H1632 M1172,762 H1382 V692 H1632"/>
                    <Path Stroke="#FF9F19" StrokeThickness="2" Data="M15,362 H130 V302 H250 M1432,402 H1552 V332 H1652 M1102,901 V831 H1262 V791"/>
                    <Path Stroke="#2BD8FF" StrokeThickness="1" Data="M300,40 V110 H520 V70 M720,15 V95 H900 M980,55 H1130 V20 M390,911 V841 H610 V891 M870,921 V861 H1010"/>
                    <Ellipse Canvas.Left="205" Canvas.Top="114" Width="12" Height="12" Stroke="#2BD8FF" StrokeThickness="2"/>
                    <Ellipse Canvas.Left="1460" Canvas.Top="195" Width="12" Height="12" Stroke="#FF9F19" StrokeThickness="2"/>
                    <Ellipse Canvas.Left="1247" Canvas.Top="784" Width="12" Height="12" Stroke="#2BD8FF" StrokeThickness="2"/>
                </Canvas>
            </Viewbox>

            <Grid x:Name="DesignSurface" Margin="9" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="68"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition x:Name="DashboardRow" Height="*" MinHeight="300"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition x:Name="FooterRow" Height="180" MinHeight="92" MaxHeight="380"/>
                </Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.72*" MinWidth="310" MaxWidth="470"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="19,0,0,0">
                        <Grid Width="56" Height="56">
                            <Ellipse Fill="#071D28" Stroke="{DynamicResource Amber}" StrokeThickness="2" Effect="{StaticResource AmberGlow}"/>
                            <Ellipse Margin="4" Stroke="{DynamicResource Cyan}" StrokeThickness="1.1"/>
                            <Image Source="Assets/AppIcon.png" Width="43" Height="43" Stretch="Uniform"/>
                            <Image Source="{DynamicResource ThemeSymbolImage}" Opacity="0.96" Width="30" Height="30"
                                   Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-8,-6"/>
                        </Grid>
                        <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="TiHiY" FontSize="28" FontWeight="Black" Foreground="{DynamicResource Cyan}"/>
                                <TextBlock Text="  StreamControl Center" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource Amber}"/>
                            </StackPanel>
                            <TextBlock Text="MULTICHAT  •  DONATIONS  •  OBS AUDIO  •  MUSIC" Foreground="#8DA1AD" FontSize="11.5" FontWeight="SemiBold"/>
                            <Border Height="2" Width="330" HorizontalAlignment="Left" Margin="0,4,0,0">
                                <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#48CCFF" Offset="0"/><GradientStop Color="#F7B81E" Offset="0.55"/><GradientStop Color="#00FFD23F" Offset="1"/></LinearGradientBrush></Border.Background>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,17,0">
                        <TextBlock Text="МАСШТАБ" Foreground="{DynamicResource Muted}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <Button Content="−" Width="35" Height="31" MinHeight="0" Padding="0" Click="ZoomOut_Click"/>
                        <Button x:Name="ZoomTextButton" Content="АВТО 98%" MinWidth="88" Height="31" MinHeight="0" Padding="7,0" Click="ZoomAuto_Click" Style="{StaticResource AmberButton}"/>
                        <Button Content="+" Width="35" Height="31" MinHeight="0" Padding="0" Click="ZoomIn_Click"/><Button x:Name="LayoutEditButton" Content="МАКЕТ: ЗАКРІПЛЕНО" Height="31" MinWidth="132" MinHeight="0" Padding="8,0" Margin="8,2,2,2" Click="ToggleLayoutEdit_Click" ToolTip="Один клік: дозволити перестановку блоків. Другий клік: закріпити поточний макет."/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowButton}" Content="—" Click="Minimize_Click"/>
                        <Button Style="{StaticResource WindowButton}" Content="□" Click="Maximize_Click"/>
                        <Button Style="{StaticResource DangerButton}" Content="×" Width="38" Height="30" MinHeight="0" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>

                <!-- STATUS + PRIMARY ACTIONS -->
                <Grid Grid.Row="1" Margin="5,2,5,8">
  <Grid.ColumnDefinitions><ColumnDefinition Width="1.08*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
  <WrapPanel VerticalAlignment="Center" ItemHeight="38">
    <Border Style="{StaticResource StatusPill}">
      <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/obs.png" Style="{StaticResource PlatformIconImage}" Width="18" Height="18" Margin="0,0,7,0"/><Ellipse x:Name="ObsDot" Width="8" Height="8" Fill="{DynamicResource Red}" Margin="0,0,6,0"/><TextBlock Text="OBS AUDIO" FontWeight="Bold"/><TextBlock x:Name="ObsStatusText" Text="  ВІДКЛЮЧЕНО" Foreground="{DynamicResource Red}" FontWeight="Bold"/></StackPanel>
    </Border>
    <Border Style="{StaticResource StatusPill}">
      <StackPanel Orientation="Horizontal"><Ellipse x:Name="BridgeDot" Width="9" Height="9" Fill="{DynamicResource Yellow}" Margin="0,0,7,0"/><TextBlock Text="MULTISTREAM" FontWeight="Bold"/><TextBlock x:Name="BridgeStatusText" Text="  НЕ ПЕРЕВІРЕНО" Foreground="{DynamicResource Yellow}" FontWeight="Bold"/></StackPanel>
    </Border>
    <Border Style="{StaticResource StatusPill}" BorderBrush="#7047B9">
      <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" Style="{StaticResource PlatformIconImage}" Width="18" Height="18"/><TextBlock Text="  TWITCH: " Foreground="{DynamicResource Muted}"/><TextBlock x:Name="TwitchTopStatusText" Text="OFF" Foreground="#B98AFF" FontWeight="Bold"/></StackPanel>
    </Border>
    <Border Style="{StaticResource StatusPill}" BorderBrush="#A8333A">
      <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Style="{StaticResource PlatformIconImage}" Width="20" Height="18"/><TextBlock Text="  YOUTUBE: " Foreground="{DynamicResource Muted}"/><TextBlock x:Name="YouTubeTopStatusText" Text="OFF" Foreground="#FF6868" FontWeight="Bold"/></StackPanel>
    </Border>
  </WrapPanel>
  <UniformGrid Grid.Column="1" Rows="1" Columns="3" VerticalAlignment="Center" Margin="8,0,0,0">
    <Button x:Name="ConnectObsButton" Click="ConnectObs_Click" Style="{StaticResource PrimaryActionButton}">
      <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/obs.png" Style="{StaticResource PlatformIconImage}"/><TextBlock x:Name="ConnectObsButtonText" Text="  ПІДКЛЮЧИТИ OBS"/></StackPanel>
    </Button>
    <Button Click="OpenChannels_Click" Style="{StaticResource PrimaryActionButton}">
      <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" Style="{StaticResource PlatformIconImage}"/><TextBlock Text="  КАНАЛИ"/></StackPanel>
    </Button>
    <Button Click="OpenSettings_Click" Style="{StaticResource PrimaryActionButton}">
      <StackPanel Orientation="Horizontal"><TextBlock Style="{StaticResource IconGlyph}" Text=""/><TextBlock Text="  НАЛАШТУВАННЯ"/></StackPanel>
    </Button>
  </UniformGrid>
</Grid><!-- DASHBOARD -->
                <Grid x:Name="DashboardBlocksGrid" Grid.Row="2" Margin="5,0,5,7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="TopLeftColumn" Width="1.02*" MinWidth="230"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition x:Name="TopRightColumn" Width="1*" MinWidth="230"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="MainTopRow" Height="1.28*" MinHeight="185"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition x:Name="MainBottomRow" Height="1*" MinHeight="205"/>
                    </Grid.RowDefinitions>
                    <GridSplitter Grid.Column="1" Grid.Row="0" Style="{StaticResource LayoutSplitter}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Cursor="SizeWE" DragCompleted="LayoutSplitter_DragCompleted" MouseDoubleClick="LayoutSplitter_MouseDoubleClick"/>
                    <GridSplitter Grid.Row="1" Grid.ColumnSpan="3" Style="{StaticResource LayoutSplitter}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Cursor="SizeNS" DragCompleted="LayoutSplitter_DragCompleted" MouseDoubleClick="LayoutSplitter_MouseDoubleClick"/>
                    <ContentControl x:Name="ChatBlockPanel" AllowDrop="True" PreviewMouseLeftButtonDown="DashboardBlock_PreviewMouseLeftButtonDown" PreviewMouseMove="DashboardBlock_PreviewMouseMove" DragOver="DashboardBlock_DragOver" Drop="DashboardBlock_Drop" Grid.Row="0" Grid.Column="0" Style="{StaticResource HudPanel}" Margin="0,0,4,4" Padding="18,13,16,13">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="52"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="55"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="МУЛЬТИЧАТ • TWITCH + YOUTUBE" Style="{StaticResource HeaderText}"/>
                                    <TextBlock x:Name="ChatStatusText" Text="Twitch чат • YouTube синхронізація • 0 повідомлень" Style="{StaticResource TinyLabel}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#281537" BorderBrush="#9254E9" BorderThickness="1" CornerRadius="4" Padding="9,5" Margin="3">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" Style="{StaticResource PlatformIconImage}" Width="20" Height="20"/>
                                            <TextBlock Text="  👁 " FontFamily="Segoe UI Emoji" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TwitchViewerText" Text="0" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Ellipse x:Name="TwitchLiveDot" Width="9" Height="9" Fill="{DynamicResource Muted}" Margin="10,0,5,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TwitchLiveText" Text="ON" Foreground="{DynamicResource Green}" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#321216" BorderBrush="#D44349" BorderThickness="1" CornerRadius="4" Padding="9,5" Margin="3">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Style="{StaticResource PlatformIconImage}" Width="22" Height="20"/>
                                            <TextBlock Text="  👁 " FontFamily="Segoe UI Emoji" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="YouTubeViewerText" Text="0" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Text="  ♥ " Foreground="#FF6B6B" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="YouTubeLikesText" Text="0" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Ellipse x:Name="YouTubeLiveDot" Width="9" Height="9" Fill="{DynamicResource Muted}" Margin="10,0,5,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="YouTubeLiveText" Text="ON" Foreground="{DynamicResource Red}" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1" Background="#01070B" BorderBrush="#10475B" BorderThickness="1" CornerRadius="2" Padding="9,7">
                                <Grid>
                                    <ListBox x:Name="MainChatList" ItemsSource="{Binding MainChatMessages}" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" PreviewMouseRightButtonDown="MainChatList_PreviewMouseRightButtonDown">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:ChatMessage}">
                                                <Border Background="{Binding Background}" CornerRadius="3" Padding="3,5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="145"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding DisplayTime}" Foreground="#748E9A" FontFamily="Consolas" FontSize="11"/>
                                                        <Border Grid.Column="1" Width="20" Height="20" CornerRadius="3" Background="{Binding PlatformColor}" HorizontalAlignment="Left">
                                                            <Image Source="{Binding PlatformIconPath}" Stretch="Uniform" Margin="2"/></Border>
                                                        <TextBlock Grid.Column="2" Text="{Binding User}" Foreground="{Binding Foreground}" FontWeight="Bold" TextTrimming="CharacterEllipsis" Margin="2,0,8,0"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Text}" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock x:Name="ChatEmptyStateText" Text="Підключіть Twitch або YouTube у модулі «Канали»." Foreground="{DynamicResource Muted}" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420" FontSize="14"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="0.86*"/>
                                    <ColumnDefinition Width="0.86*"/>
                                    <ColumnDefinition Width="0.92*"/>
                                    <ColumnDefinition Width="66"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ChatInput" KeyDown="ChatInput_KeyDown" ToolTip="Напишіть повідомлення…" MinHeight="36" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="➤" FontSize="17" Padding="0" MinHeight="36" VerticalAlignment="Stretch" Click="SendBoth_Click"/>
                                <Button x:Name="SendTwitchButton" MinHeight="36" VerticalAlignment="Stretch" Grid.Column="2" Click="SendTwitch_Click" BorderBrush="#8350C2" Background="#281238">
                                    <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" Style="{StaticResource PlatformIconImage}" Width="18" Height="18"/><TextBlock Text="  TWITCH"/></StackPanel>
                                </Button>
                                <Button x:Name="SendYouTubeButton" MinHeight="36" VerticalAlignment="Stretch" Grid.Column="3" Click="SendYouTube_Click" BorderBrush="#C2353D" Background="#301116">
                                    <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Style="{StaticResource PlatformIconImage}" Width="18" Height="18"/><TextBlock Text="  YOUTUBE"/></StackPanel>
                                </Button>
