<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="UkraineNavy0">#020B19</Color>
    <Color x:Key="UkraineNavy1">#06152A</Color>
    <Color x:Key="UkraineNavy2">#0A2544</Color>
    <Color x:Key="UkraineBlue">#119EEB</Color>
    <Color x:Key="UkraineBlueSoft">#1E6EAA</Color>
    <Color x:Key="UkraineGold">#F5A900</Color>
    <Color x:Key="UkraineGoldHot">#FFD24A</Color>

    <LinearGradientBrush x:Key="UkraineWindowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#020817" Offset="0"/>
        <GradientStop Color="#031225" Offset="0.46"/>
        <GradientStop Color="#020916" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="UkrainePanelBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F0082038" Offset="0"/>
        <GradientStop Color="#F0041325" Offset="0.58"/>
        <GradientStop Color="#F0020C18" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="UkraineButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF0B3159" Offset="0"/>
        <GradientStop Color="#FF082441" Offset="0.52"/>
        <GradientStop Color="#FF041427" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="UkraineGoldButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF4D3500" Offset="0"/>
        <GradientStop Color="#FF271D04" Offset="0.55"/>
        <GradientStop Color="#FF110D03" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="UkraineRedButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF5C151A" Offset="0"/>
        <GradientStop Color="#FF301014" Offset="0.55"/>
        <GradientStop Color="#FF16080A" Offset="1"/>
    </LinearGradientBrush>

    <DropShadowEffect x:Key="UkraineBlueGlow" Color="#168ED8" BlurRadius="9" ShadowDepth="0" Opacity="0.45"/>
    <DropShadowEffect x:Key="UkraineGoldGlow" Color="#E89C00" BlurRadius="9" ShadowDepth="0" Opacity="0.42"/>
    <DropShadowEffect x:Key="UkrainePanelShadow" Color="#000000" BlurRadius="14" ShadowDepth="4" Opacity="0.6"/>

    <Style x:Key="UkraineHeaderText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#F5A900"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="HudPanel" TargetType="ContentControl">
        <Setter Property="Foreground" Value="#E9F5FF"/>
        <Setter Property="Background" Value="{StaticResource UkrainePanelBrush}"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid x:Name="Root" ClipToBounds="True" SnapsToDevicePixels="True">
                        <Border Margin="4,5,0,0" CornerRadius="8" Background="#A0000000"/>
                        <Border x:Name="Outer" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="#D99A00" BorderThickness="1.4" Effect="{StaticResource UkrainePanelShadow}"/>
                        <Border Margin="3" CornerRadius="6" Background="Transparent" BorderBrush="#1475B8" BorderThickness="1.2"/>
                        <Border Margin="6" CornerRadius="5" Background="Transparent" BorderBrush="#4A0B3C68" BorderThickness="1"/>
                        <Path Data="M0,24 L0,8 L8,0 L58,0" Stroke="#F6AD00" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                        <Path Data="M58,24 L58,8 L50,0 L0,0" Stroke="#F6AD00" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2"/>
                        <Path Data="M0,0 L0,18 L8,26 L48,26" Stroke="#168FD6" StrokeThickness="1.4" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="4"/>
                        <Path Data="M48,0 L48,18 L40,26 L0,26" Stroke="#168FD6" StrokeThickness="1.4" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="4"/>
                        <Image Source="/TiHiY.StreamControlCenter;component/Assets/Themes/UkraineExact/panel-corner.png"
                               Width="64" Height="130" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top"
                               Opacity="{DynamicResource ThemePremiumAccentOpacity}" IsHitTestVisible="False"/>
                        <Image Source="/TiHiY.StreamControlCenter;component/Assets/Themes/UkraineExact/small-wheat.png"
                               Width="112" Height="62" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                               Margin="0,0,8,2" Opacity="{DynamicResource ThemePremiumAccentOpacity}" IsHitTestVisible="False"/>
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="BorderBrush" Value="#FFC31A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="UkraineInnerPanel" TargetType="ContentControl">
        <Setter Property="Foreground" Value="#E9F5FF"/>
        <Setter Property="Background" Value="#D9041528"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border Background="{TemplateBinding Background}" BorderBrush="#145E91" BorderThickness="1" CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatusPill" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource UkraineButtonBrush}"/>
        <Setter Property="BorderBrush" Value="#235D86"/>
        <Setter Property="BorderThickness" Value="1.2"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Effect" Value="{StaticResource UkraineBlueGlow}"/>
    </Style>

    <Style x:Key="CompactStatusPill" TargetType="Border" BasedOn="{StaticResource StatusPill}">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="2,2"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Effect" Value="{x:Null}"/>
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button">
        <Setter Property="Foreground" Value="#F4F9FF"/>
        <Setter Property="Background" Value="{StaticResource UkraineButtonBrush}"/>
        <Setter Property="BorderBrush" Value="#168ED8"/>
        <Setter Property="BorderThickness" Value="1.3"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="46"/>
        <Setter Property="Margin" Value="5,3"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root">
                        <Border x:Name="Outer" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5"/>
                        <Border Margin="3" BorderBrush="#382E79A9" BorderThickness="1" CornerRadius="3"/>
                        <Path Data="M0,10 L0,0 L22,0" Stroke="#F6A800" StrokeThickness="1.7" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                        <Path Data="M22,10 L22,0 L0,0" Stroke="#F6A800" StrokeThickness="1.7" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Outer" Property="BorderBrush" Value="#FFC21D"/><Setter TargetName="Root" Property="Effect" Value="{StaticResource UkraineGoldGlow}"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="Root" Property="Opacity" Value="0.75"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Root" Property="Opacity" Value="0.42"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CompactTopActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>

    <Style x:Key="UkraineRedActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
        <Setter Property="Background" Value="{StaticResource UkraineRedButtonBrush}"/>
        <Setter Property="BorderBrush" Value="#D53138"/>
    </Style>

    <Style x:Key="CompactTopRedActionButton" TargetType="Button" BasedOn="{StaticResource CompactTopActionButton}">
        <Setter Property="Background" Value="{StaticResource UkraineRedButtonBrush}"/>
        <Setter Property="BorderBrush" Value="#D53138"/>
    </Style>

    <Style x:Key="ModuleButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
        <Setter Property="Height" Value="48"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="MinWidth" Value="190"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Margin" Value="5,4"/>
    </Style>
    <Style x:Key="ModuleAmberButton" TargetType="Button" BasedOn="{StaticResource ModuleButton}">
        <Setter Property="Background" Value="{StaticResource UkraineGoldButtonBrush}"/>
        <Setter Property="BorderBrush" Value="#E5A300"/>
    </Style>

    <Style x:Key="WindowButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
        <Setter Property="Width" Value="42"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
        <Setter Property="Background" Value="#251015"/>
        <Setter Property="BorderBrush" Value="#D3343C"/>
    </Style>
</ResourceDictionary>