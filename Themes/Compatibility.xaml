<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Compatibility resources required by the restored v1.0.5.2 windows. -->

    <Style x:Key="IconGlyph" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="{DynamicResource Amber}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="HudPanel" TargetType="ContentControl">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="{DynamicResource PanelGradient}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button">
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="Padding" Value="11,6"/>
        <Setter Property="Margin" Value="4,2"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="{DynamicResource ButtonGradient}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Cyan}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="#391017"/>
        <Setter Property="BorderBrush" Value="#D54150"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="9,5"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="WindowButton" TargetType="Button">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="MinWidth" Value="34"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="#071620"/>
        <Setter Property="BorderBrush" Value="#164354"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ModuleAmberButton" TargetType="Button">
        <Setter Property="Width" Value="140"/>
        <Setter Property="MinWidth" Value="132"/>
        <Setter Property="MaxWidth" Value="144"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="5,4"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="9.6"/>
        <Setter Property="Foreground" Value="#FFF4CF"/>
        <Setter Property="Background" Value="{DynamicResource AmberButtonGradient}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Amber}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PlatformIconImage" TargetType="Image">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <DataTemplate x:Key="BrandButtonContentTemplate">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Image Source="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}"
                   Style="{StaticResource PlatformIconImage}" Width="19" Height="19"/>
            <TextBlock Text="{Binding}" Margin="7,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

    <Style x:Key="StatusPill" TargetType="Border">
        <Setter Property="Background" Value="#06131B"/>
        <Setter Property="BorderBrush" Value="#1A5266"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="ComboToggleStyle" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="#071923"/>
        <Setter Property="BorderBrush" Value="#1B5B70"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="9,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
</ResourceDictionary>
