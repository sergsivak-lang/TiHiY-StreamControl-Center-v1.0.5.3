<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===============================================================
         TiHiY StreamControl Center — Cyber Amber design system
         All colors are DynamicResource-ready so later themes can replace
         the same semantic keys without rewriting functional XAML.
         =============================================================== -->

    <Color x:Key="ColorBg0">#02070C</Color>
    <Color x:Key="ColorBg1">#05111A</Color>
    <Color x:Key="ColorPanel">#071823</Color>
    <Color x:Key="ColorPanel2">#0A2230</Color>
    <Color x:Key="ColorPanelHover">#0D2E3E</Color>
    <Color x:Key="ColorPanelDeep">#030D14</Color>
    <Color x:Key="ColorLine">#11465C</Color>
    <Color x:Key="ColorLineSoft">#0B3040</Color>
    <Color x:Key="ColorCyan">#28D8FF</Color>
    <Color x:Key="ColorCyanSoft">#0BA7D4</Color>
    <Color x:Key="ColorAmber">#FFAA00</Color>
    <Color x:Key="ColorAmberHot">#FF7A00</Color>
    <Color x:Key="ColorGreen">#16E36F</Color>
    <Color x:Key="ColorYellow">#FFD23B</Color>
    <Color x:Key="ColorRed">#FF3848</Color>
    <Color x:Key="ColorPurple">#9A54FF</Color>
    <Color x:Key="ColorText">#EAF8FF</Color>
    <Color x:Key="ColorMuted">#88A8B8</Color>

    <SolidColorBrush x:Key="Bg0" Color="{StaticResource ColorBg0}"/>
    <SolidColorBrush x:Key="Bg1" Color="{StaticResource ColorBg1}"/>
    <SolidColorBrush x:Key="Panel" Color="{StaticResource ColorPanel}"/>
    <SolidColorBrush x:Key="Panel2" Color="{StaticResource ColorPanel2}"/>
    <SolidColorBrush x:Key="PanelHover" Color="{StaticResource ColorPanelHover}"/>
    <SolidColorBrush x:Key="PanelDeep" Color="{StaticResource ColorPanelDeep}"/>
    <SolidColorBrush x:Key="Line" Color="{StaticResource ColorLine}"/>
    <SolidColorBrush x:Key="LineSoft" Color="{StaticResource ColorLineSoft}"/>
    <SolidColorBrush x:Key="Cyan" Color="{StaticResource ColorCyan}"/>
    <SolidColorBrush x:Key="CyanSoft" Color="{StaticResource ColorCyanSoft}"/>
    <SolidColorBrush x:Key="Amber" Color="{StaticResource ColorAmber}"/>
    <SolidColorBrush x:Key="AmberHot" Color="{StaticResource ColorAmberHot}"/>
    <SolidColorBrush x:Key="Green" Color="{StaticResource ColorGreen}"/>
    <SolidColorBrush x:Key="Yellow" Color="{StaticResource ColorYellow}"/>
    <SolidColorBrush x:Key="Red" Color="{StaticResource ColorRed}"/>
    <SolidColorBrush x:Key="Purple" Color="{StaticResource ColorPurple}"/>
    <SolidColorBrush x:Key="Text" Color="{StaticResource ColorText}"/>
    <SolidColorBrush x:Key="Muted" Color="{StaticResource ColorMuted}"/>

    <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#02070C" Offset="0"/>
        <GradientStop Color="#06131D" Offset="0.5"/>
        <GradientStop Color="#02080D" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeaderBackground" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#061A27" Offset="0"/>
        <GradientStop Color="#04111A" Offset="0.55"/>
        <GradientStop Color="#020A10" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0A2130" Offset="0"/>
        <GradientStop Color="#06151F" Offset="0.42"/>
        <GradientStop Color="#030D14" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ModuleBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A2634" Offset="0"/>
        <GradientStop Color="#061722" Offset="0.65"/>
        <GradientStop Color="#041019" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AmberButtonBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#4A2A02" Offset="0"/>
        <GradientStop Color="#1C1205" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BlueButtonBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#063A59" Offset="0"/>
        <GradientStop Color="#071B2A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="RedButtonBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#56131B" Offset="0"/>
        <GradientStop Color="#260A0F" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PurpleButtonBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#35165A" Offset="0"/>
        <GradientStop Color="#160C28" Offset="1"/>
    </LinearGradientBrush>

    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>

    <DropShadowEffect x:Key="CyanGlow" Color="#28D8FF" BlurRadius="10" ShadowDepth="0" Opacity="0.24"/>
    <DropShadowEffect x:Key="AmberGlow" Color="#FF9D00" BlurRadius="13" ShadowDepth="0" Opacity="0.30"/>
    <DropShadowEffect x:Key="SoftShadow" Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.55"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
    </Style>

    <Style x:Key="CyberHeaderText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Cyan}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="PanelBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
    </Style>

    <Style x:Key="CyberInnerBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelDeep}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LineSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <Style x:Key="StatusChip" TargetType="Border">
        <Setter Property="Background" Value="#0B1A23"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Padding" Value="11,7"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <!-- BUTTONS -->
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="{DynamicResource BlueButtonBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CyanSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="Outer" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3"/>
                        <Border x:Name="Inner" Margin="3" BorderBrush="#254E6574" BorderThickness="1" CornerRadius="2"/>
                        <Rectangle x:Name="TopAccent" Height="1" Fill="{TemplateBinding BorderBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="8,0,8,0"/>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource Cyan}"/>
                            <Setter TargetName="Inner" Property="BorderBrush" Value="#8036DFFF"/>
                            <Setter TargetName="Outer" Property="Effect" Value="{StaticResource CyanGlow}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Outer" Property="Opacity" Value="0.72"/>
                            <Setter TargetName="Inner" Property="Margin" Value="4,4,2,2"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Outer" Property="Opacity" Value="0.34"/>
                            <Setter Property="Foreground" Value="#55717E"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AmberButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource AmberButtonBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Amber}"/>
        <Setter Property="Foreground" Value="#FFF5D6"/>
    </Style>
    <Style x:Key="BlueButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource BlueButtonBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Cyan}"/>
    </Style>
    <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource RedButtonBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Red}"/>
    </Style>
    <Style x:Key="PurpleButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource PurpleButtonBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Purple}"/>
    </Style>
    <Style x:Key="TitleButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="42"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="#07151F"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>
    <Style x:Key="CloseTitleButton" TargetType="Button" BasedOn="{StaticResource TitleButton}">
        <Setter Property="Background" Value="{DynamicResource RedButtonBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Red}"/>
    </Style>

    <Style x:Key="ModuleButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource ModuleBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CyanSoft}"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="MinHeight" Value="54"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style x:Key="AmberModuleButton" TargetType="Button" BasedOn="{StaticResource ModuleButton}">
        <Setter Property="Background" Value="{DynamicResource AmberButtonBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Amber}"/>
    </Style>

    <!-- INPUTS -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="{DynamicResource PanelDeep}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Cyan}"/>
        <Setter Property="Padding" Value="9,7"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="SelectionBrush" Value="#6657DFFF"/>
    </Style>
    <Style TargetType="PasswordBox">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="{DynamicResource PanelDeep}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Cyan}"/>
        <Setter Property="Padding" Value="9,7"/>
        <Setter Property="MinHeight" Value="34"/>
    </Style>

    <Style x:Key="ComboToggleStyle" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="ClickMode" Value="Press"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="ComboChrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                            <ContentPresenter Margin="10,0,4,0" VerticalAlignment="Center" HorizontalAlignment="Left" RecognizesAccessKey="True"/>
                            <Border Grid.Column="1" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,0,0,0">
                                <Path Data="M 0 0 L 5 5 L 10 0 Z" Fill="{DynamicResource Amber}" Width="10" Height="5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ComboChrome" Property="BorderBrush" Value="{DynamicResource Cyan}"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter TargetName="ComboChrome" Property="Opacity" Value="0.45"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="{DynamicResource PanelDeep}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton" Style="{StaticResource ComboToggleStyle}"
                                      Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                      Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      Foreground="{TemplateBinding Foreground}" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                        <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                            <Border Background="#081923" BorderBrush="{DynamicResource Amber}" BorderThickness="1" CornerRadius="3" MinWidth="{Binding ActualWidth, ElementName=ToggleButton}" MaxHeight="380" Effect="{StaticResource AmberGlow}">
                                <ScrollViewer Margin="2" CanContentScroll="True"><ItemsPresenter/></ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="#081923"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True"><Setter Property="Background" Value="#133245"/><Setter Property="Foreground" Value="{DynamicResource Cyan}"/></Trigger>
            <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#3A2604"/><Setter Property="Foreground" Value="{DynamicResource Amber}"/></Trigger>
        </Style.Triggers>
    </Style>

    <!-- LISTS -->
    <Style TargetType="ListBox">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="{DynamicResource PanelDeep}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>
    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="7"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="BorderBrush" Value="#163846"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0B2A39"/></Trigger>
            <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#3B2908"/><Setter Property="BorderBrush" Value="{DynamicResource Amber}"/></Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Box" Width="17" Height="17" Background="#041019" BorderBrush="{DynamicResource CyanSoft}" BorderThickness="1" CornerRadius="2" Margin="0,0,7,0">
                            <Path x:Name="Check" Data="M 2 8 L 6 12 L 15 3" Stroke="{DynamicResource Amber}" StrokeThickness="2" Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True"><Setter TargetName="Check" Property="Visibility" Value="Visible"/><Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Amber}"/></Trigger>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Box" Property="Effect" Value="{StaticResource CyanGlow}"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SLIDER -->
    <Style TargetType="Slider">
        <Setter Property="Height" Value="20"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Margin="0,2">
                        <Border Height="5" Background="#0A2733" BorderBrush="#164A5D" BorderThickness="1" CornerRadius="2" VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" IsHitTestVisible="False" Background="{DynamicResource Amber}">
                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Height="5" Background="{TemplateBinding Background}" CornerRadius="2" VerticalAlignment="Center"/></ControlTemplate></RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="13" Height="13">
                                    <Thumb.Template><ControlTemplate TargetType="Thumb"><Ellipse Fill="{DynamicResource Amber}" Stroke="#FFF4C0" StrokeThickness="1" Effect="{StaticResource AmberGlow}"/></ControlTemplate></Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" IsHitTestVisible="False">
                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource Amber}"/>
        <Setter Property="Background" Value="#071923"/>
        <Setter Property="BorderBrush" Value="#17465A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2"/>
                        <Border x:Name="PART_Track" Margin="1" CornerRadius="1"/>
                        <Border x:Name="PART_Indicator" HorizontalAlignment="Left" Margin="1" Background="{TemplateBinding Foreground}" CornerRadius="1" Effect="{StaticResource AmberGlow}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="GridSplitter">
        <Setter Property="Background" Value="#0D4052"/>
        <Setter Property="ShowsPreview" Value="True"/>
        <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource Amber}"/></Trigger></Style.Triggers>
    </Style>

    <!-- SCROLLBARS -->
    <Style x:Key="ScrollThumb" TargetType="Thumb">
        <Setter Property="Background" Value="#315466"/>
        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Thumb"><Border Background="{TemplateBinding Background}" CornerRadius="3" Margin="2"/></ControlTemplate></Setter.Value></Setter>
        <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource Amber}"/></Trigger></Style.Triggers>
    </Style>
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="#041019"/>
        <Setter Property="Width" Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton><RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/></Track.DecreaseRepeatButton>
                            <Track.Thumb><Thumb Style="{StaticResource ScrollThumb}"/></Track.Thumb>
                            <Track.IncreaseRepeatButton><RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/></Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource PanelDeep}"/>
        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#183A48"/>
        <Setter Property="RowBackground" Value="#06131C"/>
        <Setter Property="AlternatingRowBackground" Value="#081B25"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#0B2835"/>
        <Setter Property="Foreground" Value="{DynamicResource Cyan}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
        <Setter Property="Background" Value="#06141E"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="Padding" Value="13,8"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True"><Setter Property="Foreground" Value="{DynamicResource Amber}"/><Setter Property="Background" Value="#19200F"/></Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
