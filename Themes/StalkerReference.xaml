<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Approved STALKER theme. All keys are isolated so the Ukraine theme remains untouched. -->
    <Color x:Key="StalkerBlack">#080907</Color>
    <Color x:Key="StalkerPanel">#15160F</Color>
    <Color x:Key="StalkerPanelRaised">#242219</Color>
    <Color x:Key="StalkerRust">#9A571F</Color>
    <Color x:Key="StalkerAmber">#D69A35</Color>
    <Color x:Key="StalkerRadiation">#78C83C</Color>
    <Color x:Key="StalkerText">#DDD8C7</Color>
    <Color x:Key="StalkerMuted">#969183</Color>

    <SolidColorBrush x:Key="StalkerTextBrush" Color="{StaticResource StalkerText}"/>
    <SolidColorBrush x:Key="StalkerMutedBrush" Color="{StaticResource StalkerMuted}"/>
    <SolidColorBrush x:Key="StalkerRustBrush" Color="{StaticResource StalkerRust}"/>
    <SolidColorBrush x:Key="StalkerAmberBrush" Color="{StaticResource StalkerAmber}"/>
    <SolidColorBrush x:Key="StalkerRadiationBrush" Color="{StaticResource StalkerRadiation}"/>

    <LinearGradientBrush x:Key="StalkerWindowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#080907" Offset="0"/>
        <GradientStop Color="#11130D" Offset="0.42"/>
        <GradientStop Color="#070806" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="StalkerPanelBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F024241A" Offset="0"/>
        <GradientStop Color="#F014160F" Offset="0.55"/>
        <GradientStop Color="#F0090A07" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="StalkerButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF343026" Offset="0"/>
        <GradientStop Color="#FF201D17" Offset="0.50"/>
        <GradientStop Color="#FF0E0F0B" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="StalkerDangerButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF4C2119" Offset="0"/>
        <GradientStop Color="#FF28130F" Offset="0.55"/>
        <GradientStop Color="#FF120A08" Offset="1"/>
    </LinearGradientBrush>

    <ImageBrush x:Key="StalkerMetalTextureBrush"
                ImageSource="/TiHiY.StreamControlCenter;component/Assets/Themes/StalkerExact/rusted-metal.png"
                Stretch="UniformToFill" TileMode="Tile" Viewport="0,0,512,512"
                ViewportUnits="Absolute" Opacity="0.30"/>
    <ImageBrush x:Key="StalkerScratchesBrush"
                ImageSource="/TiHiY.StreamControlCenter;component/Assets/Themes/StalkerExact/scratches.png"
                Stretch="UniformToFill" TileMode="Tile" Viewport="0,0,512,512"
                ViewportUnits="Absolute" Opacity="0.22"/>

    <DropShadowEffect x:Key="StalkerGreenGlow" Color="#65D637" BlurRadius="9" ShadowDepth="0" Opacity="0.42"/>
    <DropShadowEffect x:Key="StalkerAmberGlow" Color="#C47A22" BlurRadius="8" ShadowDepth="0" Opacity="0.35"/>
    <DropShadowEffect x:Key="StalkerPanelShadow" Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.72"/>

    <Style x:Key="StalkerHeaderText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource StalkerAmberBrush}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="StalkerHudPanel" TargetType="ContentControl">
        <Setter Property="Foreground" Value="{StaticResource StalkerTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource StalkerPanelBrush}"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid ClipToBounds="True" SnapsToDevicePixels="True">
                        <Border Margin="5,6,0,0" CornerRadius="3" Background="#B0000000"/>
                        <Border x:Name="Outer" CornerRadius="3" Background="{TemplateBinding Background}"
                                BorderBrush="#875124" BorderThickness="2" Effect="{StaticResource StalkerPanelShadow}"/>
                        <Border Margin="3" CornerRadius="2" BorderBrush="#514A35" BorderThickness="1"/>
                        <Border Margin="6" CornerRadius="1" BorderBrush="#301D160E" BorderThickness="1"/>
                        <Rectangle Margin="8" Fill="{StaticResource StalkerMetalTextureBrush}" IsHitTestVisible="False"/>
                        <Rectangle Margin="8" Fill="{StaticResource StalkerScratchesBrush}" IsHitTestVisible="False"/>
                        <Path Data="M0,24 L0,7 L7,0 L64,0" Stroke="#C17C2D" StrokeThickness="2"
                              HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                        <Path Data="M64,24 L64,7 L57,0 L0,0" Stroke="#5F692E" StrokeThickness="2"
                              HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="2"/>
                        <Image Source="/TiHiY.StreamControlCenter;component/Assets/Themes/StalkerExact/hazard-corner.png"
                               Width="78" Height="78" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top"
                               Opacity="0.80" IsHitTestVisible="False"/>
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="BorderBrush" Value="#B87528"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StalkerInnerPanel" TargetType="ContentControl">
        <Setter Property="Foreground" Value="{StaticResource StalkerTextBrush}"/>
        <Setter Property="Background" Value="#DA0D0F0A"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" BorderBrush="#554B34" BorderThickness="1.2"
                                CornerRadius="2" Padding="{TemplateBinding Padding}"/>
                        <Rectangle Fill="{StaticResource StalkerScratchesBrush}" Opacity="0.45" IsHitTestVisible="False"/>
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StalkerStatusPill" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StalkerButtonBrush}"/>
        <Setter Property="BorderBrush" Value="#5F5638"/>
        <Setter Property="BorderThickness" Value="1.2"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="MinHeight" Value="36"/>
    </Style>

    <Style x:Key="StalkerActionButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource StalkerTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource StalkerButtonBrush}"/>
        <Setter Property="BorderBrush" Value="#74502A"/>
        <Setter Property="BorderThickness" Value="1.4"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root">
                        <Border x:Name="Outer" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2"/>
                        <Rectangle Margin="3" Fill="{StaticResource StalkerMetalTextureBrush}" Opacity="0.50"/>
                        <Border Margin="3" BorderBrush="#392B1A" BorderThickness="1" CornerRadius="1"/>
                        <Path Data="M0,10 L0,0 L24,0" Stroke="#C17C2D" StrokeThickness="1.6"
                              HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="BorderBrush" Value="#D29A3B"/>
                            <Setter TargetName="Root" Property="Effect" Value="{StaticResource StalkerAmberGlow}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="Root" Property="Opacity" Value="0.72"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Root" Property="Opacity" Value="0.40"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StalkerDangerButton" TargetType="Button" BasedOn="{StaticResource StalkerActionButton}">
        <Setter Property="Background" Value="{StaticResource StalkerDangerButtonBrush}"/>
        <Setter Property="BorderBrush" Value="#9A3826"/>
    </Style>

    <Style x:Key="StalkerTextBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource StalkerTextBrush}"/>
        <Setter Property="Background" Value="#E8080A07"/>
        <Setter Property="BorderBrush" Value="#54482F"/>
        <Setter Property="BorderThickness" Value="1.2"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="CaretBrush" Value="{StaticResource StalkerRadiationBrush}"/>
        <Setter Property="SelectionBrush" Value="#805F8D32"/>
    </Style>

    <Style x:Key="StalkerComboBox" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource StalkerTextBrush}"/>
        <Setter Property="Background" Value="#E814160F"/>
        <Setter Property="BorderBrush" Value="#625236"/>
        <Setter Property="BorderThickness" Value="1.2"/>
        <Setter Property="Padding" Value="7,4"/>
    </Style>
</ResourceDictionary>