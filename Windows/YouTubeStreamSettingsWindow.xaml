<services:ModuleWindowBase x:Class="TiHiY.StreamControlCenter.Windows.YouTubeStreamSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services"
        Title="Налаштування трансляції YouTube" Width="1050" Height="760" MinWidth="560" MinHeight="400"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner">
    <Border BorderBrush="{DynamicResource Line}" BorderThickness="1" Background="{DynamicResource WindowGradient}">
            <Grid x:Name="DesignSurface" Margin="10">
                <Grid.RowDefinitions><RowDefinition Height="52"/><RowDefinition/><RowDefinition Height="54"/></Grid.RowDefinitions>
                <Border Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="14,0"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Style="{StaticResource PlatformIconImage}" Width="27" Height="25"/><TextBlock Text="  НАЛАШТУВАННЯ ТРАНСЛЯЦІЇ YOUTUBE" FontSize="22" FontWeight="Bold" Foreground="#FF5656" VerticalAlignment="Center"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"><Button Style="{StaticResource WindowButton}" Content="—" Width="40" Padding="0" Click="Minimize_Click"/><Button Style="{StaticResource WindowButton}" Content="□" Width="40" Padding="0" Click="Maximize_Click"/><Button Style="{StaticResource WindowButton}" Content="×" Width="40" Padding="0" Background="#3B0D13" BorderBrush="{DynamicResource Red}" Click="Close_Click"/></StackPanel></Grid>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,12">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="88"/><RowDefinition Height="78"/><RowDefinition Height="190"/><RowDefinition Height="82"/><RowDefinition Height="82"/><RowDefinition/><RowDefinition Height="58"/></Grid.RowDefinitions>
                        <StackPanel><TextBlock Text="Трансляція" Foreground="{DynamicResource Muted}"/><Grid Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ComboBox x:Name="BroadcastCombo" DisplayMemberPath="Display" SelectionChanged="BroadcastCombo_SelectionChanged"/><Button Grid.Column="1" Content="ОНОВИТИ СПИСОК" Click="RefreshBroadcasts_Click" Background="#1453A5"/></Grid></StackPanel>
                        <StackPanel Grid.Row="1"><TextBlock Text="Назва трансляції" Foreground="{DynamicResource Muted}"/><TextBox x:Name="TitleBox" Margin="0,6,0,0"/></StackPanel>
                        <StackPanel Grid.Row="2"><TextBlock Text="Опис" Foreground="{DynamicResource Muted}"/><TextBox x:Name="DescriptionBox" Height="150" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Disabled" Margin="0,6,0,0"/></StackPanel>
                        <Grid Grid.Row="3"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel Margin="0,0,8,0"><TextBlock Text="Доступ" Foreground="{DynamicResource Muted}"/><ComboBox x:Name="PrivacyCombo" Margin="0,6,0,0" SelectedIndex="0"><ComboBoxItem Content="public"/><ComboBoxItem Content="unlisted"/><ComboBoxItem Content="private"/></ComboBox></StackPanel><StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="Запланований початок" Foreground="{DynamicResource Muted}"/><TextBox x:Name="ScheduledStartBox" Margin="0,6,0,0"/></StackPanel></Grid>
                        <Grid Grid.Row="4"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Стан" Foreground="{DynamicResource Muted}"/><TextBlock x:Name="LifeCycleText" Text="—" FontSize="17" FontWeight="Bold" Margin="0,8,0,0"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="Посилання" Foreground="{DynamicResource Muted}"/><TextBox x:Name="StreamUrlBox" IsReadOnly="True" Margin="0,6,0,0"/></StackPanel></Grid>
                        <Border Grid.Row="5" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="12"><TextBlock Text="Це вікно редагує активну або заплановану трансляцію вашого авторизованого YouTube-каналу через YouTube Data API. Для роботи спочатку авторизуйте YouTube у модулі «Канали та Discord»." Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/></Border>
                        <WrapPanel Grid.Row="6" HorizontalAlignment="Right" VerticalAlignment="Center"><Button Content="ПІДКЛЮЧИТИ / АВТОРИЗУВАТИ" Click="OpenChannels_Click" Background="#293577" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}"/><Button Content="ВІДКРИТИ YOUTUBE STUDIO" Click="OpenYouTube_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}"/><Button Content="ЗБЕРЕГТИ В YOUTUBE" Click="SaveBroadcast_Click" Background="#7C2027" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}"/></WrapPanel>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="10"><TextBlock x:Name="StatusText" Text="Натисніть «Оновити список»." Foreground="{DynamicResource Green}" VerticalAlignment="Center"/></Border>
            </Grid>
    </Border>
</services:ModuleWindowBase>
