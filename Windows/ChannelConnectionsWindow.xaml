<services:ModuleWindowBase xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services" x:Class="TiHiY.StreamControlCenter.Windows.ChannelConnectionsWindow" Title="Канали та Discord" Width="1280" Height="820" MinWidth="650" MinHeight="430" WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner">
    <Border BorderBrush="{DynamicResource Line}" BorderThickness="1" Background="{DynamicResource WindowGradient}">
            <Grid x:Name="DesignSurface" Margin="10">
                <Grid.RowDefinitions><RowDefinition Height="52"/><RowDefinition/><RowDefinition Height="54"/></Grid.RowDefinitions>
                <Border Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="14,0"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" Style="{StaticResource PlatformIconImage}" Width="25" Height="25"/><TextBlock Text="  КАНАЛИ ТРАНСЛЯЦІЙ ТА DISCORD" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Cyan}" VerticalAlignment="Center"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"><Button Style="{StaticResource WindowButton}" Content="—" Width="40" Padding="0" Click="Minimize_Click"/><Button Style="{StaticResource WindowButton}" Content="□" Width="40" Padding="0" Click="Maximize_Click"/><Button Style="{StaticResource WindowButton}" Content="×" Width="40" Padding="0" Background="#3B0D13" BorderBrush="{DynamicResource Red}" Click="Close_Click"/></StackPanel></Grid>
                </Border>
                <Grid Grid.Row="1" Margin="0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" MinWidth="270"/><ColumnDefinition Width="6"/><ColumnDefinition Width="*" MinWidth="270"/><ColumnDefinition Width="6"/><ColumnDefinition Width="*" MinWidth="270"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PanelBorder}" Margin="0,0,7,0">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="72"/><RowDefinition Height="72"/><RowDefinition Height="72"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" Style="{StaticResource PlatformIconImage}" Width="25" Height="25"/><TextBlock Text="  TWITCH" FontSize="20" FontWeight="Bold" Foreground="#A970FF" VerticalAlignment="Center"/></StackPanel>
                            <StackPanel Grid.Row="1"><TextBlock Text="Канал" Foreground="{DynamicResource Muted}"/><TextBox x:Name="TwitchChannelBox" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Row="2"><TextBlock Text="Client ID" Foreground="{DynamicResource Muted}"/><TextBox x:Name="TwitchClientIdBox" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Row="3"><TextBlock Text="Client Secret" Foreground="{DynamicResource Muted}"/><PasswordBox x:Name="TwitchClientSecretBox" Margin="0,5,0,0"/></StackPanel>
                            <CheckBox Grid.Row="4" x:Name="TwitchAutoConnectCheck" Content="Автопідключення при запуску" Margin="0,8"/>
                            <UniformGrid Grid.Row="5" Columns="2" Margin="-3,2,-3,0">
                                <Button Content="АВТОРИЗУВАТИ" Click="AuthorizeTwitch_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#4B2A73" HorizontalAlignment="Stretch"/>
                                <Button Content="ПІДКЛЮЧИТИ" Click="ConnectTwitch_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" HorizontalAlignment="Stretch"/>
                                <Button Content="ВІДКЛЮЧИТИ" Click="DisconnectTwitch_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" HorizontalAlignment="Stretch"/>
                                <Button Content="ЗАБУТИ" Click="ForgetTwitch_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#6E1B24" BorderBrush="#D54150" HorizontalAlignment="Stretch"/>
                            </UniformGrid>
                            <StackPanel Grid.Row="6" Margin="0,12,0,0"><TextBlock x:Name="TwitchStatusText" Text="Не підключено" FontWeight="Bold" TextWrapping="Wrap"/><TextBlock Text="Redirect URI у Twitch Developer Console:" Foreground="{DynamicResource Muted}" Margin="0,12,0,3"/><TextBox Text="http://localhost:17846/twitch/" IsReadOnly="True"/><TextBlock Text="Потрібні права чату. Авторизація відкриється у браузері." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/></StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource PanelBorder}" Margin="7,0">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="72"/><RowDefinition Height="72"/><RowDefinition Height="72"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Style="{StaticResource PlatformIconImage}" Width="27" Height="25"/><TextBlock Text="  YOUTUBE" FontSize="20" FontWeight="Bold" Foreground="#FF4B4B" VerticalAlignment="Center"/></StackPanel>
                            <StackPanel Grid.Row="1"><TextBlock Text="Назва каналу" Foreground="{DynamicResource Muted}"/><TextBox x:Name="YouTubeChannelBox" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Row="2"><TextBlock Text="Google OAuth Client ID" Foreground="{DynamicResource Muted}"/><TextBox x:Name="YouTubeClientIdBox" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Row="3"><TextBlock Text="Google OAuth Client Secret" Foreground="{DynamicResource Muted}"/><PasswordBox x:Name="YouTubeClientSecretBox" Margin="0,5,0,0"/></StackPanel>
                            <CheckBox Grid.Row="4" x:Name="YouTubeAutoConnectCheck" Content="Автопідключення при запуску" Margin="0,8"/>
                            <UniformGrid Grid.Row="5" Columns="2" Margin="-3,2,-3,0">
                                <Button Content="АВТОРИЗУВАТИ" Click="AuthorizeYouTube_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#7C2027" BorderBrush="#D54150" HorizontalAlignment="Stretch"/>
                                <Button Content="ПІДКЛЮЧИТИ" Click="ConnectYouTube_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" HorizontalAlignment="Stretch"/>
                                <Button Content="ВІДКЛЮЧИТИ" Click="DisconnectYouTube_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" HorizontalAlignment="Stretch"/>
                                <Button Content="ЗАБУТИ" Click="ForgetYouTube_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#6E1B24" BorderBrush="#D54150" HorizontalAlignment="Stretch"/>
                            </UniformGrid>
                            <StackPanel Grid.Row="6" Margin="0,12,0,0"><TextBlock x:Name="YouTubeStatusText" Text="Не підключено" FontWeight="Bold" TextWrapping="Wrap"/><TextBlock Text="Redirect URI у Google Cloud Console:" Foreground="{DynamicResource Muted}" Margin="0,12,0,3"/><TextBox Text="http://127.0.0.1:17847/" IsReadOnly="True"/><TextBlock Text="У Google Cloud має бути ввімкнений YouTube Data API v3." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/></StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="7,0,0,0">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="66"/><RowDefinition Height="66"/><RowDefinition Height="105"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" Style="{StaticResource PlatformIconImage}" Width="27" Height="25"/><TextBlock Text="  DISCORD BOT" FontSize="20" FontWeight="Bold" Foreground="#7C8CFF" VerticalAlignment="Center"/></StackPanel>
                            <StackPanel Grid.Row="1"><TextBlock Text="Application ID" Foreground="{DynamicResource Muted}"/><TextBox x:Name="DiscordApplicationIdBox" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Row="2"><TextBlock Text="Bot Token" Foreground="{DynamicResource Muted}"/><PasswordBox x:Name="DiscordTokenBox" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Row="3"><TextBlock Text="ID текстових каналів (через кому або з нового рядка)" Foreground="{DynamicResource Muted}"/><TextBox x:Name="DiscordChannelsBox" Height="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Row="4"><CheckBox x:Name="DiscordEnabledCheck" Content="Увімкнути оповіщення про старт"/><WrapPanel><CheckBox x:Name="DiscordTwitchCheck"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/><TextBlock Text="  Twitch" VerticalAlignment="Center"/></StackPanel></CheckBox><CheckBox x:Name="DiscordYouTubeCheck"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/><TextBlock Text="  YouTube" VerticalAlignment="Center"/></StackPanel></CheckBox></WrapPanel></StackPanel>
                            <StackPanel Grid.Row="5" Margin="0,8,0,0"><TextBlock Text="Шаблон повідомлення" Foreground="{DynamicResource Muted}"/><TextBox x:Name="DiscordTemplateBox" Height="90" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel>
                            <UniformGrid Grid.Row="6" Columns="2" Margin="-3,2,-3,0">
                                <Button Content="СТВОРИТИ БОТА" Click="OpenDiscordPortal_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#293577" HorizontalAlignment="Stretch"/>
                                <Button Content="ДОДАТИ НА СЕРВЕР" Click="OpenDiscordInvite_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#293577" HorizontalAlignment="Stretch"/>
                                <Button Content="ЗБЕРЕГТИ" Click="SaveDiscord_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#293577" HorizontalAlignment="Stretch"/>
                                <Button Content="ТЕСТ У КАНАЛИ" Click="TestDiscord_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" HorizontalAlignment="Stretch"/>
                                <Button Content="ЗАБУТИ ТОКЕН" Click="ForgetDiscord_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#6E1B24" BorderBrush="#D54150" HorizontalAlignment="Stretch"/>
                                <Border/>
                            </UniformGrid>
                            <StackPanel Grid.Row="7" Margin="0,12,0,0"><TextBlock x:Name="DiscordStatusText" Text="Не налаштовано" FontWeight="Bold" TextWrapping="Wrap"/><TextBlock Text="Бот має бути доданий на сервер і мати право Send Messages у вибраних каналах." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/></StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                <Border Grid.Row="2" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="10"><Grid><TextBlock x:Name="FooterStatusText" Text="Токени та секрети зберігаються у Windows Credential Manager, не в settings.json." Foreground="{DynamicResource Green}" VerticalAlignment="Center"/><Button Content="ЗБЕРЕГТИ ЗВИЧАЙНІ НАЛАШТУВАННЯ" HorizontalAlignment="Right" Click="SaveGeneral_Click"/></Grid></Border>
            </Grid>
    </Border>
</services:ModuleWindowBase>
