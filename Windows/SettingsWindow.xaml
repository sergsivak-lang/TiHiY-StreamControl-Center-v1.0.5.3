<services:ModuleWindowBase x:Class="TiHiY.StreamControlCenter.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services"
        Title="Налаштування та журнал" Width="1160" Height="760" MinWidth="610" MinHeight="400" WindowStyle="None" ResizeMode="CanResize">
    <Border BorderBrush="{DynamicResource Line}" BorderThickness="1" Background="{DynamicResource WindowGradient}">
            <Grid x:Name="DesignSurface" Margin="12">
                <Grid.RowDefinitions><RowDefinition Height="56"/><RowDefinition/><RowDefinition Height="58"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="14,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="SYSTEM SETTINGS" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/><TextBlock Text="  •  OBS PASSWORD + SCALE + LOG" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/></StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"><Button Style="{StaticResource WindowButton}" Content="—" Width="40" Height="32" Padding="0" Click="Minimize_Click"/><Button Style="{StaticResource WindowButton}" Content="□" Width="40" Height="32" Padding="0" Click="Maximize_Click"/><Button Style="{StaticResource WindowButton}" Content="×" Width="40" Height="32" Padding="0" Background="#3B0D13" BorderBrush="{DynamicResource Red}" Click="Close_Click"/></StackPanel>
                    </Grid>
                </Border>
                <Grid Grid.Row="1" Margin="0,12,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="1.25*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="ІНТЕРФЕЙС І ОФОРМЛЕННЯ" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Cyan}" Margin="0,0,0,8"/>
                                    <WrapPanel><CheckBox x:Name="AutoScaleCheck" Content="Автоматичний масштаб" Checked="AutoScaleCheck_Changed" Unchecked="AutoScaleCheck_Changed"/><TextBlock Text="Ручний масштаб:" VerticalAlignment="Center" Margin="15,0,5,0"/><Button Content="−" Width="40" Click="ScaleDown_Click"/><TextBlock x:Name="ScaleText" Text="100%" Width="58" TextAlignment="Center" VerticalAlignment="Center"/><Button Content="+" Width="40" Click="ScaleUp_Click"/></WrapPanel>
                                    <TextBlock Text="Тема програми" Foreground="{DynamicResource Muted}" Margin="3,12,0,4"/>
                                    <ComboBox x:Name="ThemeCombo" SelectionChanged="ThemeCombo_SelectionChanged" MinHeight="34"/>
                                    <Border x:Name="ThemePreviewBorder" Background="{DynamicResource PanelGradient}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="0" Margin="0,7,0,0" MinHeight="170" ClipToBounds="True">
                                        <Grid>
                                            <Image x:Name="ThemePreviewImage" Stretch="UniformToFill" Opacity="0.82"/>
                                            <Border Background="#A8051324" Margin="8" CornerRadius="5" Padding="12">
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <StackPanel><TextBlock x:Name="ThemePreviewName" Text="TiHiY Default / Cyber Amber" Foreground="{DynamicResource Cyan}" FontWeight="Bold" FontSize="17"/><TextBlock x:Name="ThemePreviewDescription" Text="Попередній перегляд теми" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,5,10,0"/></StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Ellipse x:Name="ThemePreviewPrimary" Width="24" Height="24" Fill="{DynamicResource Cyan}" Margin="3"/><Ellipse x:Name="ThemePreviewAccent" Width="24" Height="24" Fill="{DynamicResource Amber}" Margin="3"/><Ellipse x:Name="ThemePreviewSuccess" Width="24" Height="24" Fill="{DynamicResource Green}" Margin="3"/></StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="Вибір змінює лише попередній перегляд. Для зміни всієї програми натисніть «ЗАСТОСУВАТИ ТЕМУ»." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="3,7,0,0"/>
                                    <WrapPanel Margin="0,9,0,0"><Button Content="ЗАСТОСУВАТИ ТЕМУ" Click="ApplyTheme_Click" Style="{StaticResource AmberButton}"/><Button Content="ВІДНОВИТИ TiHiY DEFAULT" Click="RestoreDefaultTheme_Click"/></WrapPanel>
                                    <WrapPanel Margin="0,7,0,12"><Button Content="ВІДНОВИТИ СТАНДАРТНИЙ МАКЕТ" Click="ResetDashboardLayout_Click"/></WrapPanel>

                                    <Border BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Margin="0,2,0,10"/>
                                    <TextBlock Text="OBS WEBSOCKET" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/>
                                    <Grid Margin="0,7,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,6,0"><TextBlock Text="Адреса OBS WebSocket" Foreground="{DynamicResource Muted}"/><TextBox x:Name="ObsUrlBox" Text="ws://127.0.0.1:4455" Margin="0,4,0,0"/></StackPanel>
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="Пароль" Foreground="{DynamicResource Muted}"/><PasswordBox x:Name="ObsPasswordBox" Margin="0,4,0,0"/></StackPanel>
                                    </Grid>
                                    <WrapPanel Margin="0,7,0,0"><CheckBox x:Name="RememberPasswordCheck" Content="Запам’ятати пароль"/><CheckBox x:Name="AutoConnectCheck" Content="Підключатися автоматично" Margin="12,3,3,3"/></WrapPanel>
                                    <WrapPanel Margin="0,6,0,0"><Button Content="ЗБЕРЕГТИ Й ПІДКЛЮЧИТИ" Click="SaveAndConnect_Click" Background="#1453A5" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/obs.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}"/><Button Content="ВІДКЛЮЧИТИ OBS" Click="Disconnect_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/obs.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}"/><Button Content="ЗАБУТИ ПАРОЛЬ" Click="ForgetPassword_Click" Background="#7C2027"/></WrapPanel>
                                    <TextBlock x:Name="ObsStatusText" Text="OBS не підключено" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="4,6,0,4"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="8,0,0,0">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition/><RowDefinition Height="50"/></Grid.RowDefinitions>
                            <Grid><TextBlock Text="ЖУРНАЛ ПОДІЙ" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/><TextBlock Text="Останні 14 записів" HorizontalAlignment="Right" Foreground="{DynamicResource Muted}"/></Grid>
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding VisibleLogs}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="14" Columns="1"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="7,4"><TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource Muted}"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="ОЧИСТИТИ" Click="ClearLog_Click"/><Button Content="ВІДКРИТИ ПАПКУ LOGS" Click="OpenLogs_Click" Background="#123B32"/></StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                <Border Grid.Row="2" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="9">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" Text="Пароль не зберігається у settings.json або GitHub" Foreground="{DynamicResource Green}" VerticalAlignment="Center"/><Button Grid.Column="1" Content="ВІДКРИТИ ПАПКУ НАЛАШТУВАНЬ" Click="OpenSettingsFolder_Click"/></Grid>
                </Border>
            </Grid>
    </Border>
</services:ModuleWindowBase>
