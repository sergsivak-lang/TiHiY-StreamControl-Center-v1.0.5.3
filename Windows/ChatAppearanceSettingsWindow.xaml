<services:ModuleWindowBase x:Class="TiHiY.StreamControlCenter.Windows.ChatAppearanceSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services"
        Title="Налаштування мультичату" Width="1180" Height="790" MinWidth="920" MinHeight="650"
        WindowStyle="None" ResizeMode="CanResize">
    <Border BorderBrush="{DynamicResource Line}" BorderThickness="1" Background="{DynamicResource WindowGradient}">
        <Grid x:Name="DesignSurface" Margin="12">
            <Grid.RowDefinitions><RowDefinition Height="64"/><RowDefinition/><RowDefinition Height="62"/></Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="27" Foreground="{DynamicResource Amber}" Margin="0,0,12,0"/>
                        <StackPanel><TextBlock Text="НАЛАШТУВАННЯ МУЛЬТИЧАТУ" FontSize="22" FontWeight="Black" Foreground="{DynamicResource Amber}"/><TextBlock Text="MULTICHAT • OBS CHAT OVERLAY • GAME OVERLAY" Foreground="{DynamicResource Cyan}" FontSize="12"/></StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowButton}" Content="—" Width="40" Height="32" Padding="0" Click="Minimize_Click"/>
                        <Button Style="{StaticResource WindowButton}" Content="□" Width="40" Height="32" Padding="0" Click="Maximize_Click"/>
                        <Button Style="{StaticResource DangerButton}" Content="×" Width="40" Height="32" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1" Margin="0,10,0,8" Background="Transparent">
                <TabItem Header="МУЛЬТИЧАТ У ПРОГРАМІ">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="12">
                        <Border Style="{StaticResource PanelBorder}"><Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Повідомлення чату" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Amber}"/>
                                <TextBlock Text="Розмір повідомлень" Foreground="{DynamicResource Muted}" Margin="0,14,0,3"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="68"/></Grid.ColumnDefinitions><Slider x:Name="MainFontSlider" Minimum="11" Maximum="28" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/><TextBlock x:Name="MainFontValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                <TextBlock Text="Колір тексту повідомлень" Foreground="{DynamicResource Muted}" Margin="0,12,0,3"/>
                                <TextBox x:Name="MainTextColorBox" Text="#DCE9F3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Поле введення" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Amber}"/>
                                <TextBlock Text="Розмір шрифту" Foreground="{DynamicResource Muted}" Margin="0,14,0,3"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="68"/></Grid.ColumnDefinitions><Slider x:Name="InputFontSlider" Minimum="11" Maximum="26" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/><TextBlock x:Name="InputFontValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                <TextBlock Text="Висота поля" Foreground="{DynamicResource Muted}" Margin="0,10,0,3"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="68"/></Grid.ColumnDefinitions><Slider x:Name="InputHeightSlider" Minimum="36" Maximum="64" TickFrequency="2" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/><TextBlock x:Name="InputHeightValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel Margin="0,0,6,0"><TextBlock Text="Колір тексту" Foreground="{DynamicResource Muted}"/><TextBox x:Name="InputTextColorBox"/></StackPanel><StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="Колір фону" Foreground="{DynamicResource Muted}"/><TextBox x:Name="InputBackgroundColorBox"/></StackPanel></Grid>
                            </StackPanel>
                        </Grid></Border>
                        <Border Style="{StaticResource PanelBorder}" Margin="0,10,0,0"><StackPanel><TextBlock Text="Попередній перегляд" Foreground="{DynamicResource Cyan}" FontWeight="Bold"/><Border x:Name="MainPreviewBorder" Background="#071525" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="12" Margin="0,8,0,0"><StackPanel><TextBlock x:Name="MainPreviewMessage" Text="20:38  Twitch  User123: Класний стрім! Дякую за контент!"/><TextBox x:Name="InputPreviewBox" Text="Введіть повідомлення…" Margin="0,10,0,0" IsReadOnly="True"/></StackPanel></Border></StackPanel></Border>
                    </StackPanel></ScrollViewer>
                </TabItem>

                <TabItem Header="ОВЕРЛЕЙ НА СТРІМ">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="12">
                        <Border Style="{StaticResource PanelBorder}"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="OBS Browser Source" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Amber}"/>
                                <TextBlock Text="Розмір шрифту" Foreground="{DynamicResource Muted}" Margin="0,14,0,3"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="68"/></Grid.ColumnDefinitions><Slider x:Name="StreamFontSlider" Minimum="11" Maximum="48" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/><TextBlock x:Name="StreamFontValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                <TextBlock Text="Кількість повідомлень" Foreground="{DynamicResource Muted}" Margin="0,10,0,3"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="68"/></Grid.ColumnDefinitions><Slider x:Name="StreamMaxSlider" Minimum="3" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/><TextBlock x:Name="StreamMaxValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                <TextBlock Text="Прозорість фону" Foreground="{DynamicResource Muted}" Margin="0,10,0,3"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="68"/></Grid.ColumnDefinitions><Slider x:Name="StreamOpacitySlider" Minimum="0" Maximum="0.9" TickFrequency="0.05" ValueChanged="Slider_ValueChanged"/><TextBlock x:Name="StreamOpacityValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Кольори стрім-чату" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Amber}"/>
                                <TextBlock Text="Текст повідомлення" Foreground="{DynamicResource Muted}" Margin="0,14,0,3"/><TextBox x:Name="StreamTextColorBox"/>
                                <TextBlock Text="Нік користувача" Foreground="{DynamicResource Muted}" Margin="0,10,0,3"/><TextBox x:Name="StreamUserColorBox"/>
                                <TextBlock Text="Фон" Foreground="{DynamicResource Muted}" Margin="0,10,0,3"/><TextBox x:Name="StreamBackgroundColorBox"/>
                            </StackPanel>
                        </Grid></Border>
                        <Border Style="{StaticResource PanelBorder}" Margin="0,10,0,0"><StackPanel><TextBlock Text="URL для OBS" Foreground="{DynamicResource Cyan}" FontWeight="Bold"/><TextBox x:Name="StreamOverlayUrlBox" IsReadOnly="True" Margin="0,7,0,7"/><WrapPanel><Button Content="ВІДКРИТИ ПЕРЕГЛЯД" Click="OpenStreamOverlay_Click"/><Button Content="СКОПІЮВАТИ URL" Click="CopyStreamOverlay_Click"/></WrapPanel></StackPanel></Border>
                    </StackPanel></ScrollViewer>
                </TabItem>

                <TabItem Header="ОВЕРЛЕЙ ПОВЕРХ ГРИ">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="12">
                        <Border Style="{StaticResource PanelBorder}"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Локальний чат поверх гри" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Amber}"/>
                                <CheckBox x:Name="GameAutoStartCheck" Content="Запускати разом із програмою" Margin="0,14,0,0"/>
                                <CheckBox x:Name="GameClickThroughCheck" Content="Пропускати кліки крізь overlay" Margin="0,8,0,0"/>
                                <TextBlock Text="Розмір шрифту" Foreground="{DynamicResource Muted}" Margin="0,12,0,3"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="68"/></Grid.ColumnDefinitions><Slider x:Name="GameFontSlider" Minimum="11" Maximum="42" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/><TextBlock x:Name="GameFontValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                <TextBlock Text="Кількість повідомлень" Foreground="{DynamicResource Muted}" Margin="0,10,0,3"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="68"/></Grid.ColumnDefinitions><Slider x:Name="GameMaxSlider" Minimum="3" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/><TextBlock x:Name="GameMaxValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Кольори і фон" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Amber}"/>
                                <TextBlock Text="Текст повідомлення" Foreground="{DynamicResource Muted}" Margin="0,14,0,3"/><TextBox x:Name="GameTextColorBox"/>
                                <TextBlock Text="Нік користувача" Foreground="{DynamicResource Muted}" Margin="0,10,0,3"/><TextBox x:Name="GameUserColorBox"/>
                                <TextBlock Text="Прозорість фону" Foreground="{DynamicResource Muted}" Margin="0,10,0,3"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="68"/></Grid.ColumnDefinitions><Slider x:Name="GameOpacitySlider" Minimum="0" Maximum="0.85" TickFrequency="0.05" ValueChanged="Slider_ValueChanged"/><TextBlock x:Name="GameOpacityValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                <WrapPanel Margin="0,16,0,0"><Button Content="ВІДКРИТИ OVERLAY" Click="OpenGameOverlay_Click" Background="#17613E"/><Button Content="ПРИХОВАТИ" Click="CloseGameOverlay_Click" Background="#6E1B24"/></WrapPanel>
                            </StackPanel>
                        </Grid></Border>
                    </StackPanel></ScrollViewer>
                </TabItem>
            </TabControl>

            <Border Grid.Row="2" Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="8">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText" Text="Налаштування готові" Foreground="{DynamicResource Green}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="СТАНДАРТНІ" Click="Defaults_Click"/><Button Content="ЗАСТОСУВАТИ" Click="Apply_Click"/><Button Content="ЗБЕРЕГТИ І ЗАКРИТИ" Style="{StaticResource AmberButton}" Click="Save_Click"/></StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</services:ModuleWindowBase>