<services:ModuleWindowBase x:Class="TiHiY.StreamControlCenter.Windows.JournalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services"
        Title="Журнал подій" Width="1120" Height="740" MinWidth="580" MinHeight="390"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner">
    <Border BorderBrush="{DynamicResource Line}" BorderThickness="1" Background="{DynamicResource WindowGradient}">
        <Grid x:Name="DesignSurface" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="64"/>
                <RowDefinition/>
                <RowDefinition Height="48"/>
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE8A5;" FontSize="23"/>
                        <TextBlock Text="  ЖУРНАЛ ПОДІЙ" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowButton}" Content="—" Width="40" Padding="0" Click="Minimize_Click"/>
                        <Button Style="{StaticResource WindowButton}" Content="□" Width="40" Padding="0" Click="Maximize_Click"/>
                        <Button Style="{StaticResource WindowButton}" Content="×" Width="40" Padding="0" Background="#3B0D13" BorderBrush="{DynamicResource Red}" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="10" Margin="0,10,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" ToolTip="Пошук у журналі" TextChanged="SearchBox_TextChanged" Margin="0,0,10,0"/>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Content="КОПІЮВАТИ ВИБРАНЕ" Click="CopySelected_Click"/>
                        <Button Content="КОПІЮВАТИ ВСЕ" Click="CopyAll_Click"/>
                        <Button Content="ЕКСПОРТ TXT" Click="Export_Click" Style="{StaticResource AmberButton}"/>
                        <Button Content="ВІДКРИТИ ПАПКУ" Click="OpenFolder_Click"/>
                        <Button Content="ОЧИСТИТИ ВІКНО" Click="ClearView_Click" BorderBrush="{DynamicResource Red}"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="2" Style="{StaticResource HudPanel}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition/></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="ПОДІЇ, ПІДКЛЮЧЕННЯ ТА ПОМИЛКИ" Foreground="{DynamicResource Cyan}" FontWeight="Bold"/>
                        <TextBlock x:Name="CountText" Grid.Column="1" Text="0 записів" Foreground="{DynamicResource Muted}"/>
                    </Grid>
                    <Border Grid.Row="1" Background="#02090E" BorderBrush="#19586C" BorderThickness="1" CornerRadius="5" Padding="6">
                        <ListBox x:Name="EntriesList" SelectionMode="Extended" FontFamily="Consolas" FontSize="12"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="3,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource Text}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value=""><Setter Property="Foreground" Value="{DynamicResource Muted}"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </ContentControl>

            <Border Grid.Row="3" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText" Text="Журнал готовий." Foreground="{DynamicResource Green}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Файли журналу зберігаються в AppData\TiHiY\StreamControlCenter\Logs" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</services:ModuleWindowBase>
