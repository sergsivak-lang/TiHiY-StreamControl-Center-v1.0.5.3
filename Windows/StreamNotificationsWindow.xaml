<services:ModuleWindowBase xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:services="clr-namespace:TiHiY.StreamControlCenter.Services" x:Class="TiHiY.StreamControlCenter.Windows.StreamNotificationsWindow" Title="TiHiY Stream Notify Bot" Width="1240" Height="800" MinWidth="650" MinHeight="430" WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner">
    <Border BorderBrush="{DynamicResource Line}" BorderThickness="1" Background="{DynamicResource WindowGradient}">
        <Grid x:Name="DesignSurface" Margin="10">
            <Grid.RowDefinitions><RowDefinition Height="54"/><RowDefinition/><RowDefinition Height="48"/></Grid.RowDefinitions>

            <Border Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="17" Background="#102D38" BorderBrush="{DynamicResource Green}" BorderThickness="1">
                            <TextBlock Text="N" Foreground="{DynamicResource Green}" FontSize="20" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="TIHIY STREAM NOTIFY BOT" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/>
                            <TextBlock Text="Окремі Discord-канали: трансляції та монетизація" FontSize="11" Foreground="{DynamicResource Muted}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowButton}" Content="—" Width="40" Padding="0" Click="Minimize_Click"/>
                        <Button Style="{StaticResource WindowButton}" Content="□" Width="40" Padding="0" Click="Maximize_Click"/>
                        <Button Style="{StaticResource WindowButton}" Content="×" Width="40" Padding="0" Background="#3B0D13" BorderBrush="{DynamicResource Red}" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.25*" MinWidth="500"/><ColumnDefinition Width="7"/><ColumnDefinition Width="*" MinWidth="390"/></Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" Width="24" Height="24"/><TextBlock Text="  DISCORD BOT" FontSize="18" FontWeight="Bold" Foreground="#6F83FF" VerticalAlignment="Center"/></StackPanel><Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,6,0"><TextBlock Text="Application ID" Foreground="{DynamicResource Muted}"/><TextBox x:Name="ApplicationIdBox" Margin="0,4,0,0"/></StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Text="Bot Token (порожньо = не змінювати)" Foreground="{DynamicResource Muted}"/><PasswordBox x:Name="BotTokenBox" Margin="0,4,0,0"/></StackPanel>
                            </Grid>

                            <Border Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="КАНАЛИ ПОЧАТКУ ТРАНСЛЯЦІЙ" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/>
                                    <TextBlock Text="ID каналів — через кому або з нового рядка" Foreground="{DynamicResource Muted}" Margin="0,7,0,0"/>
                                    <TextBox x:Name="ChannelIdsBox" AcceptsReturn="True" TextWrapping="Wrap" Height="48" Margin="0,4,0,0"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="Згадування" Foreground="{DynamicResource Muted}"/><TextBox x:Name="MentionBox" Margin="0,4,0,0" ToolTip="@everyone, @here, &lt;@&amp;ID_РОЛІ&gt; або порожньо"/></StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="Шаблон" Foreground="{DynamicResource Muted}"/><TextBox x:Name="TemplateBox" AcceptsReturn="True" TextWrapping="Wrap" Height="68" Margin="0,4,0,0"/></StackPanel>
                                    </Grid>
                                    <WrapPanel Margin="0,8,0,0">
                                        <CheckBox x:Name="EnabledCheck" Content="Увімкнути сповіщення про старт"/>
                                        <CheckBox x:Name="AutoStartCheck" Content="Автозапуск бота" Margin="18,3,3,3"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,5,0,0">
                                        <CheckBox x:Name="TwitchCheck" FontWeight="Bold" Foreground="#C6A6FF"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/><TextBlock Text="  TWITCH" VerticalAlignment="Center"/></StackPanel></CheckBox>
                                        <TextBlock x:Name="TwitchStateText" Text="  не підключено" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" Margin="0,0,18,0"/>
                                        <CheckBox x:Name="YouTubeCheck" FontWeight="Bold" Foreground="#FF7A7A"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/><TextBlock Text="  YOUTUBE" VerticalAlignment="Center"/></StackPanel></CheckBox>
                                        <TextBlock x:Name="YouTubeStateText" Text="  не підключено" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="#17140A" BorderBrush="#8A6B16" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="ОКРЕМИЙ КАНАЛ ДОНАТІВ І ПЛАТНИХ ПІДПИСОК" FontWeight="Bold" Foreground="{DynamicResource Yellow}"/>
                                    <TextBlock Text="ID каналів монетизації" Foreground="{DynamicResource Muted}" Margin="0,7,0,0"/>
                                    <TextBox x:Name="MonetizationChannelIdsBox" AcceptsReturn="True" TextWrapping="Wrap" Height="48" Margin="0,4,0,0"/>
                                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="Згадування" Foreground="{DynamicResource Muted}"/><TextBox x:Name="MonetizationMentionBox" Margin="0,4,0,0"/></StackPanel>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <CheckBox x:Name="MonetizationEnabledCheck" Content="Увімкнути окремі сповіщення монетизації"/>
                                            <WrapPanel Margin="0,5,0,0">
                                                <CheckBox x:Name="DonatelloMoneyCheck"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/donatello.png" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/><TextBlock Text="  Donatello" VerticalAlignment="Center"/></StackPanel></CheckBox>
                                                <CheckBox x:Name="TwitchMoneyCheck" Margin="14,3,3,3"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/twitch.png" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/><TextBlock Text="  Twitch Bits / Subs" VerticalAlignment="Center"/></StackPanel></CheckBox>
                                                <CheckBox x:Name="YouTubeMoneyCheck" Margin="14,3,3,3"><StackPanel Orientation="Horizontal"><Image Source="/TiHiY.StreamControlCenter;component/Assets/Platforms/youtube.png" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/><TextBlock Text="  YouTube Super Chat / Members" VerticalAlignment="Center"/></StackPanel></CheckBox>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="ЗБЕРЕГТИ" Click="Save_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#293577"/>
                                <Button Content="СТВОРИТИ БОТА" Click="OpenDiscordPortal_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}"/>
                                <Button Content="ДОДАТИ НА СЕРВЕР" Click="OpenDiscordInvite_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}"/>
                                <Button Content="ВІДКРИТИ КАНАЛИ" Click="OpenChannels_Click"/>
                                <Button Content="ЗАБУТИ TOKEN" Click="ForgetToken_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#6E1B24"/>
                            </WrapPanel>
                            <TextBlock Text="Bot Token зберігається у Windows Credential Manager. Канали трансляцій і монетизації працюють незалежно." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <GridSplitter Grid.Column="1" Width="7" Background="#163847" ShowsPreview="True"/>

                <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="90"/><RowDefinition Height="110"/><RowDefinition Height="Auto"/><RowDefinition Height="34"/><RowDefinition/></Grid.RowDefinitions>
                        <Border Background="#0C241D" BorderBrush="#2BEB82" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="СТАН ЛОКАЛЬНОГО БОТА" Foreground="{DynamicResource Muted}" FontWeight="Bold"/><TextBlock x:Name="BotStatusText" Text="ЗУПИНЕНО" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Yellow}" Margin="0,4,0,0"/></StackPanel>
                                <Ellipse Grid.Column="1" x:Name="BotStatusDot" Width="26" Height="26" Fill="{DynamicResource Yellow}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                            <Button Content="ЗАПУСТИТИ БОТА" Click="StartBot_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#145F43"/>
                            <Button Content="ЗУПИНИТИ" Click="StopBot_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#6E1B24"/>
                            <Button Content="ПЕРЕВІРИТИ ЗАРАЗ" Click="CheckNow_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#1453A5"/>
                            <Button Content="ТЕСТ КАНАЛУ СТРІМІВ" Click="TestDiscord_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#56408A"/>
                            <Button Content="ТЕСТ КАНАЛУ ДОНАТІВ" Click="TestMonetization_Click" Tag="/TiHiY.StreamControlCenter;component/Assets/Platforms/discord.png" ContentTemplate="{StaticResource BrandButtonContentTemplate}" Background="#7A5A10"/>
                        </WrapPanel>
                        <Border Grid.Row="2" Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,6,0,8">
                            <StackPanel><TextBlock x:Name="ConfigurationStateText" Text="Заповніть Discord Bot Token та ID каналів." TextWrapping="Wrap"/><TextBlock x:Name="LastActionText" Text="Готово до налаштування." Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel>
                        </Border>
                        <TextBlock Grid.Row="3" Text="ЖУРНАЛ БОТА" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Cyan}"/>
                        <ItemsControl Grid.Row="4" x:Name="BotLogList" Margin="0,5,0,0">
                            <ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource Panel}" BorderBrush="#173D4B" BorderThickness="0,0,0,1" Padding="7,5"><TextBlock Text="{Binding}" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="5" Padding="10">
                <Grid><TextBlock Text="TiHiY Stream Notify Bot: окремий канал стартів + окремий канал донатів і підписок." Foreground="{DynamicResource Green}" VerticalAlignment="Center"/><Button Content="ЗАКРИТИ" HorizontalAlignment="Right" Click="Close_Click"/></Grid>
            </Border>
        </Grid>
    </Border>
</services:ModuleWindowBase>
